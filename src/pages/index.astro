  <script>
    document.addEventListener('DOMContentLoaded', function() {
      (function() {
        const banner = document.querySelector('.home-urgency');
        if (!banner) return;
        window.addEventListener('scroll', function() {
          banner.classList.toggle('home-urgency-visible', window.scrollY > 150);
        }, { passive: true });
      })();

      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
      );
      document.querySelectorAll('.home-fade').forEach(el => obs.observe(el));

      document.querySelectorAll('.home-faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.home-faq-item');
          const isOpen = item.classList.contains('open');
          document.querySelectorAll('.home-faq-item.open').forEach(i => i.classList.remove('open'));
          if (!isOpen) item.classList.add('open');
        });
      });

      const services = [
        'House Cleaning','Deep Cleaning','Maid Service',
        'Handyman Services','Furniture Assembly','General Repairs',
        'Plumbing','Drain Cleaning','Leak Repair','Water Heater Installation',
        'Electrical Services','Outlet Installation','Panel Upgrade','Lighting Installation',
        'TV Mounting','TV Wall Mount','Wire Concealment',
        'Security Camera Setup','Camera Installation','Video Doorbell',
        'Smart Home Integration','Smart Thermostat','Smart Lock Installation',
        'Wi-Fi & Networking','Network Setup','Dead Zone Elimination',
        'HVAC Service','Roof Repair','Painting','Flooring','Landscaping'
      ];
      const input = document.getElementById('search-input');
      const sugBox = document.getElementById('search-suggestions');
      if (input && sugBox) {
        input.addEventListener('input', () => {
          const q = input.value.trim().toLowerCase();
          if (!q) { sugBox.style.display = 'none'; return; }
          const matches = services.filter(s => s.toLowerCase().includes(q)).slice(0, 6);
          if (!matches.length) { sugBox.style.display = 'none'; return; }
          sugBox.innerHTML = matches.map(m =>
            `<div class="suggestion-item py-2.5 px-4 text-sm cursor-pointer flex items-center gap-2.5 text-[#141210] hover:bg-[#E6F2FF]" data-suggestion="${m.replace(/"/g, '&quot;')}">
              <svg class="w-3.5 h-3.5 text-[#6B6560] flex-shrink-0" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/><path d="M10 10l2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              ${m}
            </div>`
          ).join('');
          sugBox.style.display = 'block';
          sugBox.querySelectorAll('[data-suggestion]').forEach(el => {
            el.addEventListener('click', () => {
              const val = el.getAttribute('data-suggestion');
              if (val && window.openModal) window.openModal(null, val);
              sugBox.style.display = 'none';
            });
          });
        });
        document.addEventListener('click', (e) => {
          if (!e.target.closest('.search-wrap-rel')) sugBox.style.display = 'none';
        });
        input.addEventListener('keydown', e => { if (e.key === 'Enter') handleSearch(); });
      }

      window.fillSearch = function(term) {
        if (input) input.value = term;
        if (sugBox) sugBox.style.display = 'none';
        const sel = document.getElementById('i-service');
        if (sel) { const match = Array.from(sel.options).find(o => o.text.toLowerCase().includes(term.toLowerCase())); if (match) sel.value = match.text; }
        document.getElementById('book')?.scrollIntoView({ behavior: 'smooth' });
      };
      /* Get a Quote: open modal; pass search text as service and as "Tell us about your project" */
      window.handleSearch = function() {
        const q = (input && input.value.trim()) || '';
        document.dispatchEvent(new CustomEvent('open-quote-modal', { detail: { service: q, details: q } }));
        if (sugBox) sugBox.style.display = 'none';
      };
      window.openModal = function(e, service) {
        if (e && e.preventDefault) e.preventDefault();
        document.dispatchEvent(new CustomEvent('open-quote-modal', { detail: { service: (service || '').trim() } }));
      };

      /* Inline multi-step form (prototype) */
      let inlineStep = 1;
      let inlineTiming = '';
      window.inlineNext = function(step) {
        if (step === 2) {
          if (!document.getElementById('i-service')?.value) { alert('Please select a service.'); return; }
          if (!document.getElementById('i-zip')?.value?.trim()) { alert('Please enter your ZIP code.'); return; }
        }
        if (step === 3) {
          if (!inlineTiming) { alert('Please select a timing preference.'); return; }
        }
        inlineStep = step;
        document.querySelectorAll('#inline-form-wrap .form-step').forEach((el, i) => { el.classList.toggle('active', i + 1 === step); });
        document.querySelectorAll('.progress-step').forEach((el, i) => {
          el.classList.remove('active', 'done');
          if (i + 1 < step) el.classList.add('done');
          if (i + 1 === step) el.classList.add('active');
          const dot = el.querySelector('.ps-dot');
          if (dot) { if (i + 1 < step) dot.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'; else dot.textContent = i + 1; }
        });
      };
      window.selectInlineTiming = function(el) {
        document.querySelectorAll('#inlineTimingGroup .timing-opt').forEach(o => o.classList.remove('selected'));
        el.classList.add('selected');
        inlineTiming = el.dataset.val || '';
      };
      window.submitInline = async function() {
        const name = document.getElementById('i-name')?.value?.trim() || '';
        const email = document.getElementById('i-email')?.value?.trim() || '';
        const phone = document.getElementById('i-phone')?.value?.trim() || '';
        if (!name || !email || !phone) { alert('Please fill in your name, email, and phone number.'); return; }
        const btn = document.getElementById('inline-submit-btn');
        if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
        const formData = {
          name,
          email,
          phone,
          zip: document.getElementById('i-zip')?.value?.trim() || '',
          service: document.getElementById('i-service')?.value || '',
          preferredTiming: inlineTiming || undefined,
          details: document.getElementById('i-notes')?.value?.trim() || undefined,
          formType: 'booking'
        };
        try {
          const res = await fetch('/api/send-email', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(formData) });
          if (res.ok) {
            document.getElementById('inline-form-wrap').style.display = 'none';
            document.getElementById('inline-success').style.display = 'block';
          } else {
            alert('Something went wrong. Please try again or call us.');
          }
        } catch (_) {
          alert('Something went wrong. Please try again or call us.');
        } finally {
          if (btn) { btn.disabled = false; btn.innerHTML = 'Get Free Quote <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'; }
        }
      };
    });
  </script>

  <style is:global>
    /* Urgency bar scrolls with page (not sticky) */
    /* View all services: exact accent blue from prototype */
    #main-content .view-all-services { color: #0073e6 !important; }
    #main-content .view-all-services:hover { color: #0058b0 !important; }

    /* Prototype: fonts and colors for homepage */
    #main-content { --serif: 'DM Serif Display', Georgia, serif; --sans: 'DM Sans', system-ui, sans-serif; font-family: var(--sans); -webkit-font-smoothing: antialiased; }
    #main-content .font-display, #main-content h1, #main-content h2, #main-content .step-title, #main-content .quote-form-card .form-success h3 { font-family: var(--serif); }

    /* Hero gradient overlay (prototype) */
    .hero-bg-overlay {
      background: linear-gradient(to bottom, rgba(10,14,20,0.52) 0%, rgba(10,14,20,0.38) 35%, rgba(10,14,20,0.55) 70%, rgba(10,14,20,0.82) 100%);
    }

    /* Multi-step form: hide inactive steps */
    .form-step { display: none; }
    .form-step.active { display: block; animation: home-stepIn 0.3s ease; }
    @keyframes home-stepIn { from { opacity: 0; transform: translateX(12px); } to { opacity: 1; transform: translateX(0); } }

    /* Progress steps */
    .progress-step { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; position: relative; }
    .progress-step::after { content: ''; position: absolute; top: 13px; left: 50%; width: 100%; height: 2px; background: #E8E5E0; z-index: 0; }
    .progress-step:last-child::after { display: none; }
    .ps-dot { width: 26px; height: 26px; border-radius: 50%; border: 2px solid #E8E5E0; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: #6B6560; position: relative; z-index: 1; transition: all 0.3s; }
    .progress-step.active .ps-dot { border-color: #0073e6; background: #0073e6; color: #fff; }
    .progress-step.done .ps-dot { border-color: #16a34a; background: #16a34a; color: #fff; }
    .progress-step.done::after { background: #16a34a; }
    .progress-step.active::after { background: linear-gradient(to right, #0073e6, #E8E5E0); }
    .ps-label { font-size: 10px; color: #6B6560; letter-spacing: 0.04em; white-space: nowrap; }
    .progress-step.active .ps-label { color: #0073e6; font-weight: 500; }
    .progress-step.done .ps-label { color: #16a34a; }

    /* Timing option selected state */
    .timing-opt.selected { border-color: #0073e6 !important; background: #E6F2FF !important; color: #0058b0; }
    .timing-opt.selected .timing-opt-label { color: #0058b0; }

    .home-fade { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .home-fade.visible { opacity: 1; transform: translateY(0); }
    .home-fade.home-d1 { transition-delay: 0.10s; }
    .home-fade.home-d2 { transition-delay: 0.20s; }
    .home-fade.home-d3 { transition-delay: 0.30s; }
    .home-fade.home-d4 { transition-delay: 0.40s; }
    .home-fade.home-d5 { transition-delay: 0.50s; }
    .home-urgency-dot { animation: home-pulse-dot 2s infinite; }
    @keyframes home-pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.4); } }
    .home-faq-item.open .home-faq-icon { background: #0073e6; border-color: #0073e6; }
    .home-faq-item.open .home-faq-icon svg { color: #fff; transform: rotate(45deg); }
    .home-faq-icon svg { color: #0073e6; }
    .home-faq-item.open .home-faq-answer { max-height: 320px; padding-bottom: 20px; }
    .suggestion-item:hover { background: #FEF3C7 !important; }
    @media (prefers-reduced-motion: reduce) {
      .home-fade { transition: none; }
      .home-fade.visible { opacity: 1; transform: none; }
    }
  </style>
</BaseLayout>

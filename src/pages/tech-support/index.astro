---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tv-mounting-page.css';

const title = 'Tech Support Services | Deals of Quality – On‑Site & Remote Help That Just Fixes It';
const description = 'Slow computer, broken Wi‑Fi, strange pop‑ups, or lost files? We fix your tech problems on‑site or online — remote support, computer repair, virus removal, network setup, and data recovery.';
const canonical = 'https://www.dealsofquality.com/tech-support/';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Nationwide Tech Support',
  serviceType: 'Computer & IT Help',
  description:
    'Nationwide tech support service providing remote help, computer repair, virus removal, network setup, and data recovery across 50 major US cities.',
  url: canonical,
  areaServed: { '@type': 'Country', name: 'United States' },
  provider: { '@type': 'Organization', name: 'Deals of Quality', url: 'https://www.dealsofquality.com/' },
};

const services = [
  { num: '01', name: 'Remote Support & Troubleshooting', href: '/tech-support/remote-support/', desc: '24/7 assistance for software glitches, OS errors, and cryptic error messages — resolved via secure remote access without leaving your home.', icon: 'monitor' },
  { num: '02', name: 'Computer & Device Repair', href: '/tech-support/computer-repair/', desc: 'On-site PC and Mac repair for hardware failures, broken components, slow performance, and everything in between — at your location.', icon: 'wrench' },
  { num: '03', name: 'Network Setup & Support', href: '/tech-support/network-setup/', desc: 'Wi-Fi installation, router configuration, mesh networks, and network security hardening so your connection is fast, stable, and protected.', icon: 'wifi' },
  { num: '04', name: 'Virus & Malware Removal', href: '/tech-support/virus-removal/', desc: 'Deep-scan diagnostics, complete threat elimination, and post-removal hardening to make sure what got in once, never gets in again.', icon: 'shield' },
  { num: '05', name: 'Data Backup & Recovery', href: '/tech-support/data-backup-recovery/', desc: 'Whether your hard drive crashed or you accidentally deleted years of photos — we recover it and set up backup systems so it never happens again.', icon: 'database' },
  { num: '06', name: 'Cloud Services', href: '/tech-support/cloud-services/', desc: 'Setup, migration, and ongoing management of Microsoft 365, Google Workspace, and other cloud platforms for homes and small businesses.', icon: 'cloud' },
  { num: '07', name: 'Software Support', href: '/tech-support/software-support/', desc: 'Installation, updates, license management, and performance optimization for any software application — consumer or business-grade.', icon: 'code' },
  { num: '08', name: 'Printer Setup & Support', href: '/tech-support/printer-setup/', desc: 'Printer installation, driver configuration, wireless printing setup, and troubleshooting for inkjet, laser, and all-in-one devices.', icon: 'printer' },
];

const steps = [
  { title: 'Tell Us What\'s Wrong', body: 'Call, chat, or book online. Describe the issue in plain English — we\'ll figure out the technical details.', icon: 'chat' },
  { title: 'We Match You to a Tech', body: 'A specialist for your exact issue is assigned immediately — remote or on-site, your choice.', icon: 'check' },
  { title: 'Problem Solved', body: 'We fix the issue completely, explain what happened in plain language, and make sure everything is working before we leave.', icon: 'wrench' },
  { title: 'Stay Protected', body: 'We leave you with a quick-reference guide and follow-up support so the problem stays solved long after we\'re gone.', icon: 'shield' },
];

import cities from '../../data/tech-support-cities.json';

const trustPoints = [
  { title: 'Certified on Every Platform', body: 'CompTIA A+, Microsoft Certified, Apple Authorized — our techs carry credentials, not just toolboxes.' },
  { title: 'Flat-Rate Transparent Pricing', body: 'You\'ll know the cost before we start. No surprise charges, no hourly billing that drags on forever.' },
  { title: '30-Day Service Guarantee', body: 'If the same issue returns within 30 days of our visit, we come back and fix it at no additional charge.' },
  { title: 'Remote Help in Under 15 Minutes', body: 'Average remote connection time is under 15 minutes from when you call. Fast because your time matters.' },
  { title: 'Background-Checked Technicians', body: 'Every on-site technician passes a thorough background check before they ever enter a customer\'s home.' },
];

const testimonials = [
  { quote: 'My laptop had been running slow for months. The remote session fixed everything in under 30 minutes. The tech explained exactly what was causing the issue. Worth every penny.', author: 'Sandra L.', location: 'Chicago IL', initials: 'SL' },
  { quote: 'Recovered six years of family photos from a failed hard drive I thought was gone forever. I genuinely cried. These people are miracle workers.', author: 'Marcus R.', location: 'Houston TX', initials: 'MR' },
  { quote: 'The technician showed up on time, set up our entire home network, secured it properly, and even helped my elderly mother understand how to use her tablet. Exceptional.', author: 'Jennifer P.', location: 'Denver CO', initials: 'JP' },
];

const faqs = [
  { q: 'Do you offer remote support?', a: 'Yes. We connect securely to your device and fix software glitches, OS errors, and setup issues in real time — no drive, no wait. Average connection time is under 15 minutes from when you call. Available 24/7 for remote support.' },
  { q: 'What if I need someone to come to my home?', a: 'We offer on-site tech support across 50 major US cities. Call or request a quote with your ZIP code — we\'ll match you with a technician who can come to your location for hardware repairs, network setup, printer issues, and more.' },
  { q: 'How much does tech support cost?', a: 'We quote before we start. Remote support typically runs less than an on-site visit. You\'ll get a firm price or range when you describe your issue — no surprise charges, no hourly billing that drags on.' },
  { q: 'Can you recover lost or deleted files?', a: 'Yes. Whether your hard drive crashed or you accidentally deleted years of photos, we recover data and set up backup systems so it never happens again. Data recovery success depends on the condition of the drive — we\'ll assess and give you an honest estimate.' },
  { q: 'Are your technicians certified?', a: 'Yes. Our techs are Microsoft Certified, Apple Authorized, CompTIA A+ certified, and Google Partners. We carry credentials, not just toolboxes.' },
  { q: 'Is your work guaranteed?', a: 'Yes. If the same issue returns within 30 days of our visit, we come back and fix it at no additional charge. No forms. No questions.' },
  { q: 'How do I get help?', a: 'Fill out the quote form on this page (describe your issue, ZIP, remote vs. on-site preference) or call (818) 584-7389. We respond within the hour with next steps and availability. Same-day remote support is often available immediately.' },
];

const quoteFormServices = [
  { value: 'remote-support', label: 'Remote Support & Troubleshooting' },
  { value: 'computer-repair', label: 'Computer & Device Repair' },
  { value: 'network-setup', label: 'Network Setup & Support' },
  { value: 'virus-removal', label: 'Virus & Malware Removal' },
  { value: 'data-recovery', label: 'Data Backup & Recovery' },
  { value: 'cloud-services', label: 'Cloud Services' },
  { value: 'software-support', label: 'Software Support' },
  { value: 'printer-setup', label: 'Printer Setup & Support' },
  { value: 'other', label: 'Other' },
];

const phone = 'tel:+18185847389';
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <div class="tvm-page tech-support-index">
    <!-- Urgency banner (fixed at bottom) -->
    <div class="urgency-banner urgency-banner--bottom">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">24/7 remote support available.</span> Need help now? <a href={phone}>(818) 584-7389</a></span>
    </div>

    <!-- Hero -->
    <div class="hero-wrap">
      <div class="hero-bg" style="background-color: #0f172a; background-image: url('/images/tech-support-hero.jpg'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"></div>
      <section class="hero">
        <div class="container">
          <div class="fade-up visible">
            <div class="hero-breadcrumb">
              <a href="/">Home</a>
              <span>›</span>
              <a href="/#services">Services</a>
              <span>›</span>
              Tech Support
            </div>
            <div class="hero-service-pill">
              <div class="hero-service-pill-dot"></div>
              TECH SUPPORT
            </div>
          </div>
          <h1 class="fade-up d1 visible">Your tech should just work.<br /><em>We make sure it does.</em></h1>
          <p class="hero-sub fade-up d2 visible">Slow computers, broken Wi‑Fi, strange pop‑ups, or lost files — we fix the everyday tech problems that stall your work and your life, on‑site or over a secure remote session.</p>
          <div class="hero-cta-row fade-up d3 visible">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="Tech Support">
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href={phone} style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              (818) 584-7389
            </a>
          </div>
          <div class="hero-trust-strip fade-up d4 visible">
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor"></path></svg> On‑site &amp; remote</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path></svg> 50 cities covered</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"></circle><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path></svg> 24/7 remote available</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3"></path><path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg> 30-day guarantee</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3"></rect><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg> Upfront pricing</div>
          </div>
          <div class="hero-badges fade-up d4 visible">
            <span class="hero-badge">Microsoft Certified</span>
            <span class="hero-badge">Apple Authorized</span>
            <span class="hero-badge">CompTIA A+ Techs</span>
            <span class="hero-badge">Google Partner</span>
          </div>
        </div>
      </section>
    </div>

    <!-- Proof bar -->
    <section class="proof-bar-outer">
      <div class="container">
        <div class="proof-bar-inner fade-up visible">
          <div class="proof-cell">
            <span class="proof-num">50+</span>
            <span class="proof-lbl">Cities served</span>
          </div>
          <div class="proof-cell">
            <span class="counter" data-target="4.8" data-suffix="★" data-decimal="1">4.8★</span>
            <span class="proof-lbl">Average rating</span>
          </div>
          <div class="proof-cell">
            <span class="counter" data-target="98" data-suffix="%">98%</span>
            <span class="proof-lbl">Satisfaction rate</span>
          </div>
          <div class="proof-cell">
            <span class="proof-num">30</span>
            <span class="proof-lbl">Day guarantee</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Pain section -->
    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up visible">
          <div class="section-eyebrow" style="color:#dc2626">Why Tech Problems Don't Fix Themselves</div>
          <h2 class="section-heading">Everyday tech problems that <em style="color:#dc2626">quietly steal your time.</em></h2>
          <p class="section-body">A slow laptop, "iffy" Wi‑Fi, strange pop‑ups, or a printer that only works on Tuesdays — none of these fix themselves. Left alone, they turn into missed deadlines, lost files, and hours you don't get back.</p>
        </div>
        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
            <h3>Slow machines and random crashes</h3>
            <p>You're rebooting constantly, staring at spinning wheels, and hoping this won't be the day your computer just doesn't come back on. The slow crawl drains productivity and adds stress to every task that depends on that machine.</p>
          </div>
          <div class="pain-card fade-up d1">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.5"></path><path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg></div>
            <h3>Wi‑Fi, network, and printer chaos</h3>
            <p>Calls drop, pages time out, and the printer is always "offline" when you need it most — and somehow you're the one expected to fix it. Network problems affect every device in the house and rarely resolve themselves.</p>
          </div>
          <div class="pain-card fade-up d2">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"></circle><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
            <h3>Security worries and missing files</h3>
            <p>Pop‑ups, suspicious emails, or folders that suddenly vanish. You're not sure what's broken — only that you can't afford to lose what's on that machine. Data loss and security breaches don't wait for a convenient time.</p>
          </div>
        </div>
        <div class="agitate-block fade-up d1 visible">
          <div class="agitate-text">
            <h2>The longer you wait, <em>the more it costs.</em></h2>
            <p>Most people live with "good enough" tech for months — until the slow laptop won't boot, the Wi‑Fi dies mid‑meeting, or files vanish for good. By then, a simple fix has turned into a rescue mission. Remote help can often start in minutes.</p>
          </div>
          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2 visible">
              <div class="as-num">4.2h</div>
              <div><div class="as-text-label">Average time wasted per failed DIY tech fix</div><div class="as-text-sub">Restarting, reinstalling, Googling — before you call for help anyway.</div></div>
            </div>
            <div class="agitate-stat fade-up d3 visible">
              <div class="as-num">1 in 3</div>
              <div><div class="as-text-label">people have lost important files to a tech problem</div><div class="as-text-sub">Drives fail, accounts get locked, and "I'll back up later" becomes "I wish I had."</div></div>
            </div>
            <div class="agitate-stat fade-up d4 visible">
              <div class="as-num">&lt;15 min</div>
              <div><div class="as-text-label">to start a remote session when you're ready</div><div class="as-text-sub">Fix it now — not after another week of limping along.</div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- Solution section -->
    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img class="solve-photo" src="/images/tech-support-solution.jpg" alt="Technician helping customer with computer support" loading="lazy" width="800" height="520" />
            <div class="solve-badge">
              <div class="solve-badge-icon"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg></div>
              <div><div class="solve-badge-num">4.8★</div><div class="solve-badge-label">Tech support avg. rating</div></div>
            </div>
          </div>
          <div class="solve-copy fade-up d1 visible">
            <div class="section-eyebrow">Every Tech Problem. Solved.</div>
            <h2 class="solve-heading">On‑site or online. <em>Fixed fast.</em></h2>
            <p>We don't leave you guessing. Tell us what's wrong — we match you to the right kind of help and fix it on‑site or over a secure remote session. Eight focused service areas so you don't have to figure out who to call.</p>
            <p>Microsoft Certified, Apple Authorized, CompTIA A+ techs. Flat-rate quotes before we start. A 30-day guarantee if the same issue returns. And for remote support — average connection time under 15 minutes from when you call.</p>
            <div class="solve-points">
              {trustPoints.slice(0, 4).map((t) => (
                <div class="solve-point">
                  <div class="sp-icon"><svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
                  <div class="sp-text"><strong>{t.title}.</strong> <span>{t.body}</span></div>
                </div>
              ))}
            </div>
            <button type="button" class="btn-primary-gold tvm-book-btn" data-open-quote="true" data-service="Tech Support"><svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg> Get a Free Tech Support Quote</button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Services offered -->
    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro">
          <div class="section-eyebrow fade-up">What We Offer</div>
          <h2 class="section-heading fade-up d1">Eight service areas. One standard.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">From remote troubleshooting to on-site repairs, virus removal, data recovery, and everything in between — we handle it with the right expertise and transparent pricing.</p>
        </div>
        <div class="services-grid">
          {services.map((s, i) => (
            <a href={s.href} class="svc-card fade-up {i % 4 === 0 ? 'visible' : ''} {i % 4 === 1 ? 'd1 visible' : ''} {i % 4 === 2 ? 'd2 visible' : ''} {i % 4 === 3 ? 'd3 visible' : ''}">
              <div class="svc-card-top">
                <div class="svc-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"></rect><path d="M8 22h8M12 18v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg></div>
                <h3>{s.name}</h3>
              </div>
              <p>{s.desc}</p>
              <span class="svc-card-link">Learn more <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- Process -->
    <section class="process-section">
      <div class="container">
        <div class="process-intro">
          <div class="section-eyebrow fade-up">Our Process</div>
          <h2 class="section-heading fade-up d1">Help in 4 easy steps.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">No confusing menus. No waiting rooms. Getting tech help should be as simple as the problem isn't.</p>
        </div>
        <div class="process-steps fade-up d1">
          {steps.map((step, i) => (
            <div class="process-step">
              <div class="ps-num">{String(i + 1).padStart(2, '0')}</div>
              <div class="ps-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
              <span class="ps-pill">Step {String(i + 1).padStart(2, '0')}</span>
              <div class="ps-title">{step.title}</div>
              <div class="ps-text">{step.body}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Reviews -->
    <section class="reviews-section">
      <div class="container">
        <div class="reviews-intro">
          <div class="section-eyebrow fade-up">Verified Reviews</div>
          <h2 class="section-heading fade-up d1">Real reviews from real people.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">Remote sessions, on-site visits, data recovery — from Chicago to Houston and beyond.</p>
        </div>
        <div class="reviews-grid">
          {testimonials.map((t, i) => (
            <div class="review-card fade-up {i === 0 ? 'visible' : ''} {i === 1 ? 'd1 visible' : ''} {i === 2 ? 'd2 visible' : ''}">
              <span class="review-verified">✓ Verified</span>
              <div class="review-stars">★★★★★</div>
              <div class="review-quote">"{t.quote}"</div>
              <div class="review-author">
                <div class="review-initials">{t.initials}</div>
                <div>
                  <strong>{t.author}</strong>
                  <div class="review-source"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M6 1l1.2 2.6L10 4l-2 2 .5 3L6 7.8 3.5 9l.5-3L2 4l2.8-.4L6 1z" fill="currentColor"></path></svg> {t.location}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="stats-strip fade-up d1 visible">
          <div class="ss-cell"><span class="ss-num">50+</span><span class="ss-lbl">Cities served</span></div>
          <div class="ss-cell"><span class="ss-num counter" data-target="4.8" data-suffix="★" data-decimal="1">4.8★</span><span class="ss-lbl">Average rating</span></div>
          <div class="ss-cell"><span class="ss-num counter" data-target="98" data-suffix="%">98%</span><span class="ss-lbl">Satisfaction rate</span></div>
          <div class="ss-cell"><span class="ss-num">30</span><span class="ss-lbl">Day guarantee</span></div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- Guarantee strip -->
    <section class="guarantee-strip">
      <div class="container">
        <div class="guarantee-inner">

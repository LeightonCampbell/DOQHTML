---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tv-mounting-page.css';
import cities from '../../data/tech-support-cities.json';

export const prerender = true;

export function getStaticPaths() {
  return cities.map((city: { slug: string; cityName: string; state: string; localHighlight: string; localMetaDesc: string }) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
const title = `Expert Tech Support in ${city.cityName}, ${city.state} | Deals of Quality`;
const description = city.localMetaDesc;
const canonical = `https://www.dealsofquality.com/tech-support/${city.slug}/`;

const phone = 'tel:+18185847389';

const services = [
  { name: 'Remote Support & Troubleshooting', href: '/tech-support/remote-support/' },
  { name: 'Computer & Device Repair', href: '/tech-support/computer-repair/' },
  { name: 'Network Setup & Support', href: '/tech-support/network-setup/' },
  { name: 'Virus & Malware Removal', href: '/tech-support/virus-removal/' },
  { name: 'Data Backup & Recovery', href: '/tech-support/data-backup-recovery/' },
];

const quoteFormServices = [
  { value: 'remote-support', label: 'Remote Support & Troubleshooting' },
  { value: 'computer-repair', label: 'Computer & Device Repair' },
  { value: 'network-setup', label: 'Network Setup & Support' },
  { value: 'virus-removal', label: 'Virus & Malware Removal' },
  { value: 'data-recovery', label: 'Data Backup & Recovery' },
  { value: 'cloud-services', label: 'Cloud Services' },
  { value: 'software-support', label: 'Software Support' },
  { value: 'printer-setup', label: 'Printer Setup & Support' },
  { value: 'other', label: 'Other' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <div class="tvm-page">
    <div class="urgency-banner urgency-banner--bottom">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">24/7 remote support available.</span> Need help now? <a href={phone}>(818) 584-7389</a></span>
    </div>

    <div class="hero-wrap">
      <div class="hero-bg" style="background-color: #0f172a; background-image: url('/images/tech-support-hero.jpg'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"></div>
      <section class="hero">
        <div class="container">
          <div class="fade-up visible">
            <div class="hero-breadcrumb">
              <a href="/">Home</a>
              <span>›</span>
              <a href="/tech-support/">Tech Support</a>
              <span>›</span>
              {city.cityName}, {city.state}
            </div>
            <div class="hero-service-pill">
              <div class="hero-service-pill-dot"></div>
              TECH SUPPORT
            </div>
          </div>
          <h1 class="fade-up d1 visible">Expert Tech Support in {city.cityName}, {city.state}</h1>
          <p class="hero-sub fade-up d2 visible">{city.localHighlight}</p>
          <div class="hero-cta-row fade-up d3 visible">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="Tech Support">
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href={phone} style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              (818) 584-7389
            </a>
          </div>
          <div class="hero-trust-strip fade-up d4 visible">
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor"></path></svg> On‑site &amp; remote</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path></svg> Certified technicians</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"></circle><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path></svg> 24/7 remote available</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3"></path><path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg> 30-day guarantee</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3"></rect><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg> Upfront pricing</div>
          </div>
        </div>
      </section>
    </div>

    <section class="proof-bar-outer">
      <div class="container">
        <div class="proof-bar-inner fade-up visible">
          <div class="proof-cell"><span class="proof-num">50+</span><span class="proof-lbl">Cities served</span></div>
          <div class="proof-cell"><span class="counter" data-target="4.8" data-suffix="★" data-decimal="1">4.8★</span><span class="proof-lbl">Average rating</span></div>
          <div class="proof-cell"><span class="counter" data-target="98" data-suffix="%">98%</span><span class="proof-lbl">Satisfaction rate</span></div>
          <div class="proof-cell"><span class="proof-num">30</span><span class="proof-lbl">Day guarantee</span></div>
        </div>
      </div>
    </section>

    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img class="solve-photo" src="/images/tech-support-solution.jpg" alt="Technician helping customer with computer support" loading="lazy" width="800" height="520" />
            <div class="solve-badge">
              <div class="solve-badge-icon"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg></div>
              <div><div class="solve-badge-num">4.8★</div><div class="solve-badge-label">Tech support avg. rating</div></div>
            </div>
          </div>
          <div class="solve-copy fade-up d1 visible">
            <div class="section-eyebrow">Every Tech Problem. Solved.</div>
            <h2 class="solve-heading">On‑site or online. <em>Fixed fast.</em></h2>
            <p>We don't leave you guessing. Tell us what's wrong — we match you to the right kind of help and fix it on‑site or over a secure remote session. Microsoft Certified, Apple Authorized, CompTIA A+ techs. Flat-rate quotes before we start. A 30-day guarantee if the same issue returns.</p>
            <button type="button" class="btn-primary-gold tvm-book-btn" data-open-quote="true" data-service="Tech Support"><svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg> Get a Free Tech Support Quote</button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro">
          <div class="section-eyebrow fade-up">What We Offer</div>
          <h2 class="section-heading fade-up d1">Tech support services in {city.cityName}, {city.state}</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">From remote troubleshooting to on-site repairs, virus removal, data recovery, and everything in between — we handle it with the right expertise and transparent pricing.</p>
        </div>
        <div class="services-grid">
          {services.map((s, i) => (
            <a href={s.href} class="svc-card fade-up {i % 4 === 0 ? 'visible' : ''} {i % 4 === 1 ? 'd1 visible' : ''} {i % 4 === 2 ? 'd2 visible' : ''} {i % 4 === 3 ? 'd3 visible' : ''}">
              <div class="svc-card-top">
                <div class="svc-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"></rect><path d="M8 22h8M12 18v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg></div>
                <h3>{s.name}</h3>
              </div>
              <span class="svc-card-link">Learn more <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <section id="quote" class="cta-section">
      <div class="container">
        <div class="cta-grid">
          <div class="cta-copy fade-up visible">
            <div class="section-eyebrow">Get Your Quote</div>
            <h2 class="section-heading">Ready for tech that just works?</h2>
            <p>Tell us your issue, ZIP code, and whether you prefer remote or on-site support. We'll respond within an hour with next steps and availability.</p>
            <div class="urgency-callout">
              <div class="urgency-callout-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
              <div><div class="urgency-callout-title">Remote support often available immediately</div><div class="urgency-callout-text">No appointment needed for remote sessions. We'll confirm when we reply.</div></div>
            </div>
          </div>
          <div id="quote-form" class="quote-card fade-up d2 visible">
            <div class="progress-wrap">
              <div class="progress-steps">
                <div class="prog-step active" data-step="1"><div class="prog-dot">1</div><span class="prog-label">Your Issue</span></div>
                <div class="prog-step" data-step="2"><div class="prog-dot">2</div><span class="prog-label">Contact</span></div>
              </div>
            </div>
            <div id="form-wrap">
              <div class="form-step active" data-step="1">
                <div class="step-title">Your Issue</div>
                <div class="step-subtitle">Tell us what's wrong and where you're located.</div>
                <div class="form-group"><label for="ts-issue">Issue type</label><select id="ts-issue" class="form-control"><option value="">Select…</option>{quoteFormServices.map((s) => <option value={s.value}>{s.label}</option>)}</select></div>
                <div class="form-group"><label for="ts-zip">ZIP Code</label><input id="ts-zip" class="form-control" type="text" placeholder="e.g. 90210" maxlength="10" /></div>
                <div class="form-group">
                  <label>Remote or on-site?</label>
                  <div class="timing-options" id="ts-mode-group">
                    <div class="timing-opt" data-val="remote" onclick="selectTsMode(this)"><span class="timing-opt-icon">💻</span><span class="timing-opt-label">Remote</span></div>
                    <div class="timing-opt" data-val="onsite" onclick="selectTsMode(this)"><span class="timing-opt-icon">🏠</span><span class="timing-opt-label">On-site</span></div>
                    <div class="timing-opt" data-val="either" onclick="selectTsMode(this)"><span class="timing-opt-icon">🔄</span><span class="timing-opt-label">Either</span></div>
                  </div>
                </div>
                <button type="button" class="btn-next" onclick="tsNextStep(2)">Continue →</button>
              </div>
              <div class="form-step" data-step="2">
                <button type="button" class="btn-back" onclick="tsNextStep(1)">← Back</button>
                <div class="step-title">Contact</div>
                <div class="step-subtitle">How we'll send your quote and confirm.</div>
                <div class="form-group"><label for="ts-name">Full Name</label><input id="ts-name" class="form-control" type="text" placeholder="Jane Smith" /></div>
                <div class="form-group"><label for="ts-email">Email Address</label><input id="ts-email" class="form-control" type="email" placeholder="jane@example.com" /></div>
                <div class="form-group"><label for="ts-phone">Phone Number</label><input id="ts-phone" class="form-control" type="tel" placeholder="(555) 000-0000" /></div>
                <div class="form-group"><label for="ts-notes">Describe your issue <span style="color:var(--tvm-muted);font-weight:400">(optional)</span></label><textarea id="ts-notes" class="form-control" rows="2" placeholder="e.g. Laptop slow, random blue screens…"></textarea></div>
                <button type="button" class="btn-next gold" onclick="tsSubmitForm()">Get My Free Quote</button>
              </div>
            </div>
            <div id="ts-form-success" class="form-success">
              <div class="form-success-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
              <h3>Quote request received!</h3>
              <p>We'll be in touch within an hour with next steps and availability. Questions? Call us at <a href={phone}>(818) 584-7389</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="final-cta">
      <div class="container">
        <div class="section-eyebrow">Your Tech Problem Ends Today</div>
        <h2>On-site or online. We fix it.</h2>
        <p>50+ cities. Microsoft Certified, Apple Authorized, CompTIA A+ techs. Remote support in under 15 minutes. Same transparent pricing, same 30-day guarantee.</p>
        <div class="final-cta-btns">
          <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="Tech Support"><svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg> Get a Free Quote</button>
          <a class="btn-ghost-white-final" href={phone} style="color:#ffffff;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call (818) 584-7389
          </a>
        </div>
      </div>
    </section>
  </div>

  <style>
    .tvm-page .urgency-banner.urgency-banner--bottom { top: auto; bottom: 0; border-top: 1px solid rgba(255,255,255,0.08); box-shadow: 0 -4px 20px rgba(0,0,0,0.35); }
    @media (max-width: 640px) { .tvm-page .urgency-banner.urgency-banner--bottom { bottom: 72px; } }
  </style>

  <script is:inline>
    (function() {
      var obs = new IntersectionObserver(function(entries) { entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.07, rootMargin: '0px 0px -28px 0px' });
      document.querySelectorAll('.tvm-page .fade-up').forEach(function(el) { obs.observe(el); });

      function animateCounter(el) {
        var target = parseFloat(el.dataset.target);
        var decimals = parseInt(el.dataset.decimal || '0', 10);
        var suffix = el.dataset.suffix || '';
        var duration = 1800;
        var start = performance.now();
        function step(now) {
          var p = Math.min((now - start) / duration, 1);
          var e = 1 - Math.pow(1 - p, 3);
          el.textContent = decimals ? (e * target).toFixed(decimals) + suffix : Math.floor(e * target).toLocaleString() + suffix;
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = decimals ? target.toFixed(decimals) + suffix : target.toLocaleString() + suffix;
        }
        requestAnimationFrame(step);
      }
      var cObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.querySelectorAll('.counter').forEach(animateCounter); cObs.unobserve(e.target); }
        });
      }, { threshold: 0.25 });
      document.querySelectorAll('.tvm-page .proof-bar-inner').forEach(function(el) { cObs.observe(el); });

      window.selectTsMode = function(el) {
        document.querySelectorAll('#ts-mode-group .timing-opt').forEach(function(o) { o.classList.remove('selected'); });
        el.classList.add('selected');
        window.selectedTsMode = el.dataset.val;
      };
      window.tsNextStep = function(step) {
        if (step === 2) {
          if (!document.getElementById('ts-issue').value) { alert('Please select an issue type.'); return; }
          if (!document.getElementById('ts-zip').value.trim()) { alert('Please enter your ZIP code.'); return; }
          if (!window.selectedTsMode) { alert('Please select remote, on-site, or either.'); return; }
        }
        document.querySelectorAll('#quote-form .form-step').forEach(function(el, i) { el.classList.toggle('active', (el.dataset.step || (i+1)) == step); });
        document.querySelectorAll('#quote-form .prog-step').forEach(function(el, i) {
          el.classList.remove('active', 'done');
          var dot = el.querySelector('.prog-dot');
          if (i + 1 < step) { el.classList.add('done'); dot.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'; }
          else { dot.textContent = i + 1; if (i + 1 === step) el.classList.add('active'); }
        });
      };
      window.tsSubmitForm = function() {
        var name = document.getElementById('ts-name').value.trim();
        var email = document.getElementById('ts-email').value.trim();
        var phone = document.getElementById('ts-phone').value.trim();
        if (!name || !email || !phone) { alert('Please fill in all contact fields.'); return; }
        document.getElementById('form-wrap').style.display = 'none';
        document.getElementById('ts-form-success').style.display = 'block';
        document.querySelector('#quote-form .progress-wrap').style.display = 'none';
      };
    })();
  </script>
</BaseLayout>

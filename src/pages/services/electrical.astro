---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Electrical Services Los Angeles — Deals of Quality';
const description = 'Licensed electricians in Los Angeles. Outlet installation, panel upgrades, EV charger install, ceiling fans, light fixtures, and more. Upfront pricing, code-compliant work.';
const canonical = 'https://www.dealsofquality.com/services/electrical/';

const quoteFormServices = [
  { value: 'outlet-install', label: 'Outlet Installation' },
  { value: 'light-fixture', label: 'Light Fixture Replacement' },
  { value: 'panel-upgrade', label: 'Panel Upgrade & Repair' },
  { value: 'ceiling-fan', label: 'Ceiling Fan Installation' },
  { value: 'dimmer-switch', label: 'Dimmer Switch Installation' },
  { value: 'ev-charger', label: 'EV Charger Installation' },
  { value: 'gfci-outlet', label: 'GFCI Outlet Replacement' },
  { value: 'smoke-detector', label: 'Smoke & CO Detector Install' },
  { value: 'circuit-breaker', label: 'Circuit Breaker Repair' },
  { value: 'other', label: 'Other' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="electrical-main">

    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">Electrical emergency? Licensed electricians available today.</span> <a href="tel:8185847389">(818) 584-7389</a></span>
    </div>

    <div class="hero-wrap">
      <div class="hero-bg" style="background-image: url('/images/electrical-hero.jpg'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"></div>
      <section class="hero electrical-hero">
        <div class="container">
          <div class="fade-up">
            <div class="hero-breadcrumb">
              <a href="/">Home</a><span>›</span><a href="/services/">Services</a><span>›</span>Electrical
            </div>
            <div class="hero-service-pill"><div class="hero-service-pill-dot"></div>Electrical Services</div>
          </div>
          <h1 class="fade-up d1">Electrical work done safely.<br /><em>By licensed pros.</em></h1>
          <p class="hero-sub fade-up d2">Licensed electricians in Los Angeles for outlets, panels, EV chargers, ceiling fans, and more. Code-compliant work. Upfront flat-rate pricing. Same-day availability.</p>
          <div class="hero-cta-row fade-up d3">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="Electrical">
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"/></svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href="tel:8185847389" style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (818) 584-7389
            </a>
          </div>
          <div class="hero-trust-strip fade-up d4">
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor"/></svg>Licensed & insured electricians</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>100% code-compliant work</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Same-day availability</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>All work guaranteed</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>Upfront flat-rate pricing</div>
          </div>
        </div>
      </section>
    </div>

    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up">
          <div class="section-eyebrow section-eyebrow--danger">WHY ELECTRICAL ISSUES CAN'T WAIT</div>
          <h2 class="section-heading">Electrical problems aren't just inconvenient — <em>they're dangerous.</em></h2>
          <p class="section-body">Every electrical issue in your home carries risk you can't see. Here's what ignoring them — or handling them yourself — actually costs.</p>
        </div>
        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>Electrical issues are a leading cause of house fires</h3>
            <p>The National Fire Protection Association estimates 46,700+ home fires each year are caused by electrical problems — faulty wiring, overloaded circuits, and failing components. Most start inside walls where you can't see them until the damage is done. A tingling outlet or a breaker that trips repeatedly isn't an annoyance — it's a warning sign you shouldn't ignore.</p>
          </div>
          <div class="pain-card fade-up d1">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <h3>DIY electrical can void your homeowner's insurance</h3>
            <p>Most homeowner's insurance policies require electrical work to be performed by a licensed contractor. Unpermitted DIY wiring — even a simple outlet job — can be grounds to deny a claim after a fire or damage event. And if the work fails a home inspection during a sale, you're looking at a rework, a delay, and a negotiating loss you didn't see coming.</p>
          </div>
          <div class="pain-card fade-up d2">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9.5 12.5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>Unqualified electrical work fails when it matters most</h3>
            <p>An EV charger installed without proper load calculation trips breakers constantly. A panel upgrade done without permits creates liability on sale. An outlet "fixed" without understanding the underlying circuit fails again — or worse, silently overheats. Licensed electricians don't just swap parts — they understand your whole system and work it safely.</p>
          </div>
        </div>
        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>Electrical fires cause an estimated <em class="agitate-highlight">$1.3 billion in property damage</em> each year in the US.</h2>
            <p>The majority are preventable with proper maintenance and licensed repairs. Aging panels, overloaded circuits, and outdated wiring don't fail suddenly — they degrade over time, silently increasing risk. A licensed electrical inspection costs a fraction of what fire damage does.</p>
          </div>
          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2"><div class="as-num">$1.3B</div><div><div class="as-text-label">in property damage from electrical fires annually</div><div class="as-text-sub">Most are preventable with licensed repairs.</div></div></div>
            <div class="agitate-stat fade-up d3"><div class="as-num">51%</div><div><div class="as-text-label">of home electrical fires involve wiring or related equipment</div><div class="as-text-sub">Often inside walls — invisible until it's too late.</div></div></div>
            <div class="agitate-stat fade-up d4"><div class="as-num">$0</div><div><div class="as-text-label">insurance payout for DIY electrical that starts a fire</div><div class="as-text-sub">Policies require licensed work. Don't risk it.</div></div></div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img class="solve-photo" src="/images/electrical-solution.jpg" alt="Licensed electrician completing work in Los Angeles" loading="lazy" />
            <div class="solve-badge">
              <div class="solve-badge-icon"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"/></svg></div>
              <div><div class="solve-badge-num">4.9★</div><div class="solve-badge-label">Electrical avg. rating</div></div>
            </div>
          </div>
          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow section-eyebrow--accent">THE SOLUTION</div>
            <h2 class="solve-heading">Licensed electricians. Code-compliant. <em>Done right.</em></h2>
            <p>Deals of Quality connects you with California-licensed electricians who understand your home's system, diagnose issues correctly, and do work that passes inspection — because it's done by someone who knows the code.</p>
            <p>Whether you need a single outlet or a full panel upgrade, you get an upfront quote, a clean job, and a guarantee. No guesswork. No DIY workarounds. No future liability.</p>
            <div class="solve-points">
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>All work done to California electrical code.</strong> <span>Properly permitted where required. Inspected. Documented. Zero corners cut on safety.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Flat-rate quotes before any work starts.</strong> <span>You know the full cost before we touch a wire. No "time and materials" billing that blows past any estimate.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Licensed and insured — protecting your home.</strong> <span>Every electrician we send is C-10 licensed, carries general liability, and is qualified for the job scope assigned.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Workmanship guaranteed on every job.</strong> <span>If anything we installed or repaired fails within the warranty period, we come back and make it right at no cost.</span></div></div>
            </div>
            <button type="button" class="btn-primary-gold" style="display:inline-flex;width:auto;" data-open-booking="true" data-service="Electrical">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Book Electrical Service Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">ELECTRICAL SERVICES</div>
          <h2 class="section-heading section-heading--no-em">Every electrical job we handle.</h2>
          <p class="section-body">From a single outlet to a full panel upgrade, our licensed electricians handle all residential electrical needs throughout Los Angeles — safely and to code.</p>
        </div>
        <div class="services-grid">
          <a href="#quote" class="service-card fade-up" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8"/><path d="M12 12v3"/><path d="M10.5 13.5h3"/></svg></div><h3>Outlet Installation</h3></div>
            <p>New outlet installation, GFCI upgrades, USB outlets, and outlet relocation. We run proper circuits, use the correct wire gauge, and install flush, tight, and safe — whether it's one outlet or a full-room addition.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up d1" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></div><h3>Light Fixture Replacement</h3></div>
            <p>Replace overhead fixtures, pendant lights, recessed cans, bathroom vanity lights, and exterior fixtures. We handle the wiring, mounting, and switch connection — and remove the old fixture safely.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up d2" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18M2 9h20M2 15h20"/></svg></div><h3>Panel Upgrade & Repair</h3></div>
            <p>200-amp panel upgrades, subpanel additions, breaker replacement, and panel inspections. An undersized or aging panel is a liability — especially in older LA homes still running 100-amp service. We size correctly and install to code.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L8 7H4l4 5H4l8 10 4-7h4l-4-5h4L12 2z"/></svg></div><h3>Ceiling Fan Installation</h3></div>
            <p>New ceiling fan installation, replacement of old fans, and adding fan-capable wiring in rooms that currently have a light fixture only. We balance the fan, check the mounting box, and ensure the wiring can handle the load.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up d1" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M5 12H2M22 12h-3M5.64 5.64l-2.12-2.12M20.49 20.49l-2.12-2.12M5.64 18.36l-2.12 2.12M20.49 3.51l-2.12 2.12"/></svg></div><h3>Dimmer Switch Installation</h3></div>
            <p>Replace standard switches with smart dimmers for LED, incandescent, and CFL fixtures. We match the dimmer to the load type, ensure compatibility, and wire correctly — no buzzing, no flickering, no overheating.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up d2" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="16" cy="16" r="1"/></svg></div><h3>EV Charger Installation</h3></div>
            <p>Level 2 EV charger installation (240V) for all major brands — Tesla, ChargePoint, Enel X, and more. We assess your panel capacity, run a dedicated circuit, install the charger, and ensure it's permitted and utility-compliant.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 11-12.73 0"/><path d="M12 2v10"/></svg></div><h3>GFCI Outlet Replacement</h3></div>
            <p>GFCI outlet replacement in kitchens, bathrooms, garages, and outdoor areas — as required by current California electrical code. We test the circuit, replace failed GFCIs, and protect downstream outlets correctly.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up d1" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4M12 16h.01"/></svg></div><h3>Smoke & CO Detector Install</h3></div>
            <p>Hardwired smoke detector installation, carbon monoxide detector placement, and interconnected system setup. California law requires working smoke detectors in every sleeping area and on every floor — we install to code and test every unit.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#quote" class="service-card fade-up d2" onclick="scrollToQuote(); return false;">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div><h3>Circuit Breaker Repair</h3></div>
            <p>Breakers that trip repeatedly, won't reset, run hot, or have visible damage are a hazard. We test the circuit for faults, replace failed breakers with the correct amperage and brand, and ensure the panel is safe before we leave.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="process-section">
      <div class="container">
        <div class="process-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">OUR PROCESS</div>
          <h2 class="section-heading section-heading--no-em">From first contact to clean, code-compliant work — here's how it goes.</h2>
          <p class="section-body">Every step is predictable. No mystery hours, no scope surprises, no "I'll let you know" billing.</p>
        </div>
        <div class="process-grid fade-up">
          <div class="process-card">
            <span class="process-num">01</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
            <span class="process-pill">Step 01</span>
            <h3>Describe your electrical need</h3>
            <p>Fill out our quick form or call (818) 584-7389. Tell us what needs installing, repairing, or inspecting — and your ZIP code. The more specific, the more accurate your upfront quote will be.</p>
          </div>
          <div class="process-card">
            <span class="process-num">02</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <span class="process-pill">Step 02</span>
            <h3>We match a licensed electrician</h3>
            <p>We route your request to a C-10 licensed electrician in your area. You get their credentials, availability, and a flat-rate quote before you commit. Same-day slots available.</p>
          </div>
          <div class="process-card">
            <span class="process-num">03</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <span class="process-pill">Step 03</span>
            <h3>On-site assessment & quote</h3>
            <p>Your electrician assesses the job, confirms the scope, and gives you a final flat-rate price before work begins. No hidden "assessment fees" that get folded into a larger invoice.</p>
          </div>
          <div class="process-card">
            <span class="process-num">04</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg></div>
            <span class="process-pill">Step 04</span>
            <h3>Work completed, tested, guaranteed.</h3>

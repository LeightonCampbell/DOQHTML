                    <div class="timing-opt" data-val="today" onclick="selectTiming(this)"><span class="timing-opt-icon">⚡</span><span class="timing-opt-label">Today</span></div>
                    <div class="timing-opt" data-val="this-week" onclick="selectTiming(this)"><span class="timing-opt-icon">📅</span><span class="timing-opt-label">This week</span></div>
                    <div class="timing-opt" data-val="flexible" onclick="selectTiming(this)"><span class="timing-opt-icon">🕐</span><span class="timing-opt-label">Flexible</span></div>
                  </div>
                </div>
                <button type="button" class="btn-next" onclick="nextStep(2)">Continue →</button>
              </div>
              <div class="form-step" data-step="2">
                <button type="button" class="btn-back" onclick="nextStep(1)">← Back</button>
                <div class="step-title">Contact</div>
                <div class="step-subtitle">How we'll send your quote and confirm your appointment.</div>
                <div class="form-group"><label for="f-name">Full Name</label><input id="f-name" class="form-control" type="text" placeholder="Jane Smith" /></div>
                <div class="form-group"><label for="f-email">Email Address</label><input id="f-email" class="form-control" type="email" placeholder="jane@example.com" /></div>
                <div class="form-group"><label for="f-phone">Phone Number</label><input id="f-phone" class="form-control" type="tel" placeholder="(555) 000-0000" /></div>
                <div class="form-group"><label for="f-notes">Anything we should know? <span style="color:var(--muted);font-weight:400">(optional)</span></label><textarea id="f-notes" class="form-control" rows="2" placeholder="e.g. Above fireplace, stone surround, concrete wall…"></textarea></div>
                <button type="button" class="btn-next gold" onclick="submitForm()">Get My Free Quote</button>
                <p class="form-note"><svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M7 1L3 2.5v4c0 2.5 2 4.5 4 5 2-.5 4-2.5 4-5v-4L7 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path><path d="M5 7l1.5 1.5 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg> Private. Never sold. One match — no spam calls.</p>
              </div>
            </div>
            <div id="form-success" class="form-success">
              <div class="form-success-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
              <h3>Quote request received!</h3>
              <p>We'll be in touch within an hour with your firm price and next available times. Questions? Call us at <a href="tel:8185847389">(818) 584-7389</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="locations-section">
      <div class="container">
        <div class="locations-intro">
          <div class="section-eyebrow fade-up visible">Service Areas</div>
          <h2 class="section-heading fade-up d1 visible">TV mounting service near you.</h2>
          <p class="section-body fade-up d2 visible" style="margin:0 auto;">We serve Los Angeles and surrounding communities with the same professional installers, same pricing, and the same standard of work — wherever you are.</p>
        </div>
        <div class="locations-grid fade-up d1 visible">
          {locations.map((loc) => (
            <a class:list={['loc-card', { 'loc-card--current': loc.isCurrent }]} href={loc.href} aria-current={loc.isCurrent ? 'page' : undefined}>
              <div class="loc-card-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"></circle></svg></div>
              <span class="loc-card-name">{loc.name}</span>
              <span class="loc-card-sub">Serving {loc.name} and surrounding areas</span>
              <span class="loc-card-link">{loc.isCurrent ? 'Current page' : <Fragment>View page <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path></svg></Fragment>}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="final-cta">
      <div class="container">
        <div class="section-eyebrow">Culver City TV Mounting</div>
        <h2>Same-day service across all of Culver City.</h2>
        <p>3,800+ TVs mounted across the LA area. One call, one professional installer, one clean result — in every Culver City neighborhood.</p>
        <div class="final-cta-btns">
          <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="TV Mounting"><svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"></path></svg> Get a Free Quote</button>
          <a class="btn-ghost-white-final" href="tel:8185847389" style="color:#ffffff;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>Call (818) 584-7389</a>
        </div>
      </div>
    </section>

    <div class="sticky-mobile-cta">
      <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="TV Mounting">Get a Free Quote</button>
      <a class="btn-call" href="tel:8185847389" aria-label="Call"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path></svg></a>
    </div>

  </div>

  <script is:inline define:vars={{}}>
    (function() {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); });
      }, { threshold: 0.07, rootMargin: '0px 0px -28px 0px' });
      document.querySelectorAll('.tvm-page .fade-up').forEach(function(el) { obs.observe(el); });
      function animateCounter(el) {
        var target = parseFloat(el.dataset.target);
        var decimals = parseInt(el.dataset.decimal || '0', 10);
        var suffix = el.dataset.suffix || '';
        var duration = 1800;
        var start = performance.now();
        function step(now) {
          var p = Math.min((now - start) / duration, 1);
          var e = 1 - Math.pow(1 - p, 3);
          el.textContent = decimals ? (e * target).toFixed(decimals) + suffix : Math.floor(e * target).toLocaleString() + suffix;
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = decimals ? target.toFixed(decimals) + suffix : target.toLocaleString() + suffix;
        }
        requestAnimationFrame(step);
      }
      var cObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.querySelectorAll('.counter').forEach(animateCounter); cObs.unobserve(e.target); }
        });
      }, { threshold: 0.25 });
      document.querySelectorAll('.tvm-page .stats-strip, .tvm-page .proof-bar-inner').forEach(function(el) { cObs.observe(el); });
      document.querySelectorAll('.tvm-page .faq-q').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var item = btn.closest('.faq-item');
          var open = item.classList.contains('open');
          document.querySelectorAll('.tvm-page .faq-item.open').forEach(function(i) { i.classList.remove('open'); });
          if (!open) item.classList.add('open');
        });
      });
      window.nextStep = function(step) {
        if (step === 2) {
          if (!document.getElementById('f-tvsize').value) { alert('Please select a TV size.'); return; }
          if (!document.getElementById('f-zip').value.trim()) { alert('Please enter your ZIP code.'); return; }
          if (!window.selectedTiming) { alert('Please select a timing preference.'); return; }
        }
        document.querySelectorAll('.tvm-page .form-step').forEach(function(el, i) { el.classList.toggle('active', i + 1 === step); });
        document.querySelectorAll('.tvm-page .prog-step').forEach(function(el, i) {
          el.classList.remove('active', 'done');
          var dot = el.querySelector('.prog-dot');
          if (i + 1 < step) { el.classList.add('done'); dot.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'; }
          else { dot.textContent = i + 1; if (i + 1 === step) el.classList.add('active'); }
        });
      };
      window.selectTiming = function(el) {
        document.querySelectorAll('#timing-group .timing-opt').forEach(function(o) { o.classList.remove('selected'); });
        el.classList.add('selected');
        window.selectedTiming = el.dataset.val;
      };
      window.submitForm = function() {
        var name = document.getElementById('f-name').value.trim();
        var email = document.getElementById('f-email').value.trim();
        var phone = document.getElementById('f-phone').value.trim();
        if (!name || !email || !phone) { alert('Please fill in all contact fields.'); return; }
        document.getElementById('form-wrap').style.display = 'none';
        document.getElementById('form-success').style.display = 'block';
        document.querySelector('.tvm-page .progress-wrap').style.display = 'none';
      };
      window.scrollToQuote = function(e) {
        if (e) e.preventDefault();
        var el = document.getElementById('tvm-quote-form') || document.getElementById('quote');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };
      (function() {
        var banner = document.querySelector('.tvm-page .urgency-banner');
        if (!banner) return;
        var isBottom = false;
        window.addEventListener('scroll', function() {
          var shouldBeBottom = window.scrollY > 150;
          if (shouldBeBottom && !isBottom) {
            isBottom = true;
            banner.classList.add('tvm-banner-fading');
            setTimeout(function() { banner.classList.add('tvm-banner-bottom'); banner.classList.remove('tvm-banner-fading'); }, 250);
          } else if (!shouldBeBottom && isBottom) {
            isBottom = false;
            banner.classList.add('tvm-banner-fading');
            setTimeout(function() { banner.classList.remove('tvm-banner-bottom'); banner.classList.remove('tvm-banner-fading'); }, 250);
          }
        }, { passive: true });
      })();
    })();
  </script>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/homepage.css';

const canonical = 'https://www.dealsofquality.com/services/';

interface ServiceItem {
  name: string;
  description: string;
  icon: string;
  href: string;
  isHot?: boolean;
  openQuoteAtZip?: boolean;
}
interface Category {
  title: string;
  titleHref?: string;
  items: ServiceItem[];
}


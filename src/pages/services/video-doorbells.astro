---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tv-mounting-page.css';
import { getServiceLandingContent } from '../../data/serviceLandingData';
import { allServices } from '../../data/servicesData';

const slug = 'video-doorbells';
const serviceItem = allServices.find((s) => s.slug === slug);
const modalService = serviceItem?.label ?? 'Video Doorbell Setup';

const content = getServiceLandingContent(
  slug,
  'Video Doorbell Setup',
  'Video doorbell installation and setup. See who\'s at the door from your phone.'
);

const title = 'Video Doorbell Setup Los Angeles — Deals of Quality';
const description = 'Professional video doorbell installation in Los Angeles. Wired or battery setup, app pairing, and chime integration. Same-day availability when you book early.';
const canonical = 'https://www.dealsofquality.com/services/video-doorbells/';

const phoneTel = 'tel:8185847389';
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="tvm-page">
    <!-- URGENCY BANNER -->
    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span>
        Same-day video doorbell appointments available today — book before noon.
        <a href={phoneTel}>(818) 584-7389</a>
      </span>
    </div>

    <!-- HERO -->
    <div class="hero-wrap relative overflow-hidden min-h-screen flex flex-col">
      <div
        class="hero-bg-photo absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('/video-doorbell-hero.png'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"
      />
      <div class="hero-bg-overlay absolute inset-0 z-[1]" aria-hidden="true"></div>

      <section class="hero-content relative z-[2] flex-1 flex flex-col items-center justify-center py-[90px] pb-20 px-6 text-center" aria-label="Hero">
        <div class="container-max max-w-[1100px] mx-auto px-6">
          <div class="fade-up">
            <div class="hero-breadcrumb">
              <a href="/">Home</a><span>›</span>
              <a href="/services/">Services</a><span>›</span>
              Video Doorbells
            </div>

            <div class="hero-service-pill">
              <div class="hero-service-pill-dot"></div>
              Video Doorbells
            </div>
          </div>

          <h1 class="fade-up d1">
            Stop guessing.<br /><em>Doorbell ready.</em>
          </h1>

          <p class="hero-sub fade-up d2">
            Professional video doorbell installation and setup so you never miss a visitor.
            Hardwired or battery — we handle mounting, wiring checks, app pairing, and chime integration.
          </p>

          <div class="hero-cta-row fade-up d3">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service={modalService}>
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none">
                <path
                  d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z"
                  fill="currentColor"
                />
              </svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href={phoneTel} style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (818) 584-7389
            </a>
          </div>

          <div class="hero-trust-strip fade-up d4">
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                <path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor" />
              </svg>
              Vetted doorbell installers
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                <path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
              </svg>
              Licensed &amp; insured
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" />
                <path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
              </svg>
              Same-day availability
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                <path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" />
                <path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              App setup &amp; training
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                <rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3" />
                <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Upfront transparent pricing
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- PAIN -->
    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up">
          <div class="section-eyebrow section-eyebrow--danger">THE REAL COST OF WAITING</div>
          <h2 class="section-heading">
            Video doorbells that aren’t<br /><em>ready on day one.</em>
          </h2>
          <p class="section-body">
            A doorbell you can’t reliably power, pair, or hear can leave you stuck troubleshooting while deliveries slip through.
            Professional setup prevents the dead zones, wiring surprises, and app setup headaches.
          </p>
        </div>

        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Power &amp; wiring issues slow you down</h3>
            <p>
              Wrong transformer wiring or power assumptions cause chimes to fail, devices to reboot, or notifications to lag.
              We verify wiring and set it up so it stays stable.
            </p>
          </div>

          <div class="pain-card fade-up d1">
            <div class="pain-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" />
                <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>App pairing takes longer than it should</h3>
            <p>
              If you can’t get the doorbell into your Wi‑Fi, calibrate motion zones, or connect the chime,
              you’re left with a “setup in progress” device. We configure everything.
            </p>
          </div>

          <div class="pain-card fade-up d2">
            <div class="pain-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </div>
            <h3>Deliveries keep slipping through</h3>
            <p>
              Missed alerts and delayed notifications mean you never see what happened at the door.
              Proper configuration helps motion detection work when it matters.
            </p>
          </div>
        </div>

        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>The average homeowner has <em class="agitate-highlight">one “almost set up”</em> doorbell problem.</h2>
            <p>
              It starts with “just installing it”—then turns into transformer guesses, chime conflicts, and endless app retries.
              We install and configure so your doorbell is usable right away.
            </p>
          </div>
          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2">
              <div class="as-num">8s</div>
              <div>
                <div class="as-text-label">average time to enter</div>
                <div class="as-text-sub">An unprotected moment is all it takes.</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d3">
              <div class="as-num">1</div>
              <div>
                <div class="as-text-label">app that actually works</div>
                <div class="as-text-sub">Pairing + training included.</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d4">
              <div class="as-num">$0</div>
              <div>
                <div class="as-text-label">runaround on setup</div>
                <div class="as-text-sub">We finish the job and verify.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- SOLUTION -->
    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img
              class="solve-photo"
              src="/video-doorbell-hero.png"
              alt="Video doorbell installation outcome"
              loading="lazy"
            />
            <div class="solve-badge">
              <div class="solve-badge-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
                </svg>
              </div>
              <div>
                <div class="solve-badge-num">4.8★</div>
                <div class="solve-badge-label">Doorbell install avg. rating</div>
              </div>
            </div>
          </div>

          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow section-eyebrow--accent">THE SOLUTION</div>
            <h2 class="solve-heading">Professional install. <em>App-ready.</em></h2>
            <p>
              We connect you with vetted video doorbell installers in Los Angeles who handle both mounting and setup —
              wiring checks, app pairing, motion zones, and chime integration.
            </p>
            <p>
              You get a walkthrough so you know how to use your doorbell on day one.
              If anything doesn’t work, we come back and make it right.
            </p>

            <div class="solve-points">
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text">
                  <strong>Wiring checks first.</strong> <span>We confirm power options before mounting.</span>
                </div>
              </div>
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text">
                  <strong>App setup &amp; training.</strong> <span>Pairing, notifications, and motion zones.</span>
                </div>
              </div>
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text">
                  <strong>Chime &amp; smart home integration.</strong> <span>Pair the chime and connect devices when applicable.</span>
                </div>
              </div>
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text">
                  <strong>Clean, professional finish.</strong> <span>Mounting looks right and stays secure.</span>
                </div>
              </div>
            </div>

            <button
              type="button"
              class="btn-primary-gold"
              style="display:inline-flex;width:auto;"
              data-open-booking="true"
              data-service={modalService}
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Book Video Doorbell Install Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- SERVICES -->
    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">VIDEO DOORBELL SERVICES</div>
          <h2 class="section-heading section-heading--no-em">Everything you need to feel safe.</h2>
          <p class="section-body">
            We handle both the install and the setup so your doorbell works the moment we leave.
          </p>
        </div>

        <div class="services-grid">
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service={modalService} role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                </svg>
              </div>
              <h3>Hardwired Setup</h3>
            </div>
            <p>Transformer checks, secure wiring, and chime pairing so your doorbell stays powered.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4" /></svg></span>
          </a>

          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service={modalService} role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a4 4 0 0 1-4 4H7l-4 4V5a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z" />
                </svg>
              </div>
              <h3>Battery Installation</h3>
            </div>
            <p>Clean mount, stable placement, and battery guidance so you don’t lose notifications.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4" /></svg></span>
          </a>

          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service={modalService} role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 8v4l3 3" />
                  <circle cx="12" cy="12" r="10" />
                </svg>
              </div>
              <h3>App Pairing &amp; Setup</h3>
            </div>
            <p>Wi‑Fi pairing, motion zones, recordings, and notification settings configured correctly.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4" /></svg></span>
          </a>

          <a href="#" class="service-card fade-up" data-open-quote="true" data-service={modalService} role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 11h4l3 10 4-16 3 6h4" />
                </svg>
              </div>
              <h3>Chime Integration</h3>
            </div>
            <p>Doorbell chime setup so visitors always get heard.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4" /></svg></span>
          </a>

          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service={modalService} role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </div>
              <h3>Motion Zone Tuning</h3>
            </div>
            <p>Reduce false alerts with coverage planning and sensitivity tuning.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4" /></svg></span>
          </a>

          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service={modalService} role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                </svg>
              </div>
              <h3>Smart Lock / Integration</h3>
            </div>
            <p>Coordinate doorbell alerts with your smart home hub when applicable.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4" /></svg></span>
          </a>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="process-section">
      <div class="container">
        <div class="process-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">OUR PROCESS</div>
          <h2 class="section-heading section-heading--no-em">From inquiry to a working doorbell.</h2>
          <p class="section-body">
            Predictable steps so you know what happens next.
          </p>
        </div>

        <div class="process-steps">
          <div class="process-step">
            <span class="ps-num">01</span>
            <div class="ps-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
              </svg>
            </div>
            <span class="ps-pill">Step 01</span>
            <div class="ps-title">Tell us your doorbell needs</div>
            <div class="ps-text">Call or request a quote. We’ll confirm the right power and setup approach.</div>
          </div>

          <div class="process-step">
            <span class="ps-num">02</span>
            <div class="ps-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
              </svg>
            </div>
            <span class="ps-pill">Step 02</span>
            <div class="ps-title">We match a vetted installer</div>
            <div class="ps-text">Get an arrival window and a clear quote before any work begins.</div>
          </div>

          <div class="process-step">
            <span class="ps-num">03</span>
            <div class="ps-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2" />
              </svg>
            </div>
            <span class="ps-pill">Step 03</span>
            <div class="ps-title">Install + verify everything</div>
            <div class="ps-text">Mounting, wiring checks, app pairing, and test notifications.</div>
          </div>

          <div class="process-step">
            <span class="ps-num">04</span>
            <div class="ps-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6l-11 11-5-5" />
              </svg>
            </div>
            <span class="ps-pill">Step 04</span>
            <div class="ps-title">Walkthrough + you’re set</div>
            <div class="ps-text">We show you how it works and make sure it’s ready on day one.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section class="reviews-section">
      <div class="container">
        <div class="reviews-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">REAL REVIEWS</div>
          <h2 class="section-heading section-heading--no-em">Trusted for video doorbell installs.</h2>
          <p class="section-body">On time, clean work, and setup you can actually use.</p>
        </div>

        <div class="reviews-grid">
          <div class="review-card fade-up">
            <div class="review-stars" aria-hidden="true">★★★★★</div>
            <blockquote class="review-quote">
              They handled the wiring and got my app paired immediately. Motion alerts finally make sense.
            </blockquote>
            <div class="review-author">
              <span class="review-initials">LA</span>
              <div>
                <strong>Los Angeles, CA</strong>
                <div class="review-source">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  Verified customer
                </div>
              </div>
            </div>
          </div>

          <div class="review-card fade-up d1">
            <div class="review-stars" aria-hidden="true">★★★★★</div>
            <blockquote class="review-quote">
              App training was the difference. Everything works and the chime integration is perfect.
            </blockquote>
            <div class="review-author">
              <span class="review-initials">SB</span>
              <div>

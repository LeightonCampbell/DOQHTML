---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tv-mounting-page.css';
import { allServices } from '../../data/servicesData';
import { getServiceLandingContent } from '../../data/serviceLandingData';

const slug = 'video-doorbells';
const serviceItem = allServices.find((s) => s.slug === slug);
const modalService = serviceItem?.label ?? 'Video Doorbell Setup';

const content = getServiceLandingContent(slug, modalService, serviceItem?.description ?? '');
const canonical = `https://www.dealsofquality.com/${content.canonicalPath}/`;

const phoneTel = 'tel:8185847389';
const heroBg = content.heroImage ?? '/images/service-hero.jpg';

const testimonials = [
  {
    quote: 'They handled the wiring and got my app paired immediately. Motion alerts finally make sense.',
    initials: 'LA',
    author: 'Los Angeles, CA',
    rating: 5,
  },
  {
    quote: 'App training was the difference. Everything works and the chime integration is perfect.',
    initials: 'SB',
    author: 'Santa Monica, CA',
    rating: 5,
  },
  {
    quote: 'We had issues with DIY setup. They fixed the wiring, paired the device, and tuned the motion zones.',
    initials: 'BH',
    author: 'Beverly Hills, CA',
    rating: 5,
  },
];

const faqs = [
  {
    q: 'Can you install both hardwired and battery doorbells?',
    a: 'Yes. We’ll confirm your existing wiring/power options and choose the cleanest setup for your doorbell type.',
  },
  {
    q: 'Do you handle app pairing and motion settings?',
    a: 'We pair your doorbell to your phone, tune notifications/motion zones, and show you how to use it.',
  },
  {
    q: 'Will it work with my existing chime?',
    a: 'We integrate your chime where possible. If wiring updates are needed, we’ll confirm before starting.',
  },
  {
    q: 'What’s included in the install?',
    a: 'Mounting, wiring checks, app pairing, motion zone setup, and a walkthrough so your doorbell is ready to use.',
  },
  {
    q: 'How fast can I get an appointment?',
    a: 'In many cases, same-day availability is possible. Booking early helps secure the soonest slot in your ZIP.',
  },
  {
    q: 'Do you offer a guarantee?',
    a: 'Yes. If something isn’t holding up after the install, we come back and make it right.',
  },
];
---
<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={canonical}>
  <div class="tvm-page">
    <!-- URGENCY BANNER -->
    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">Same-day video doorbell appointments available.</span> Book before noon. <a href={phoneTel}>(818) 584-7389</a></span>
    </div>

    <!-- HERO -->
    <div class="hero-wrap relative overflow-hidden min-h-screen flex flex-col">
      <div
        class="hero-bg-photo absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-color:#0f172a; background-image: url('{heroBg}'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"
      />
      <div class="hero-bg-overlay absolute inset-0 z-[1]" aria-hidden="true"></div>

      <section class="hero-content relative z-[2] flex-1 flex flex-col items-center justify-center py-[90px] pb-20 px-6 text-center" aria-label="Hero">
        <div class="container-max max-w-[1100px] mx-auto px-6">
          <div class="fade-up visible">
            <div class="hero-breadcrumb">
              <a href="/">Home</a><span>›</span>
              <a href="/services/">Services</a><span>›</span>
              Video Doorbells
            </div>

            <div class="hero-service-pill">
              <div class="hero-service-pill-dot"></div>
              VIDEO DOORBELL SETUP
            </div>
          </div>

          <h1 class="fade-up d1 visible">
            Stop guessing.<br /><em>Doorbell ready.</em>
          </h1>
          <p class="hero-sub fade-up d2 visible">
            Professional video doorbell installation and setup so you never miss a visitor. Hardwired or battery — we handle mounting, wiring checks, app pairing, and chime integration.
          </p>

          <div class="hero-cta-row fade-up d3 visible">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service={modalService}>
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none">
                <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
              </svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href={phoneTel} style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (818) 584-7389
            </a>
          </div>

          <div class="hero-trust-strip fade-up d4 visible">
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor" />
              </svg>
              Vetted doorbell installers
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
              </svg>
              Licensed &amp; insured
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" />
                <path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
              </svg>
              Same-day availability
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" />
                <path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              App setup &amp; training
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3" />
                <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Upfront transparent pricing
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- PAIN -->
    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up visible">
          <div class="section-eyebrow" style="color:#dc2626">THE REAL COST OF WAITING</div>
          <h2 class="section-heading">
            Video doorbells that aren’t<br /><em>ready on day one.</em>
          </h2>
          <p class="section-body">
            A doorbell you can’t reliably power, pair, or hear can leave you stuck troubleshooting while deliveries slip through. Professional setup prevents the dead zones, wiring surprises, and app setup headaches.
          </p>
        </div>

        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Power &amp; wiring issues slow you down</h3>
            <p>Wrong transformer wiring or power assumptions can make chimes fail, devices reboot, or notifications lag. We verify wiring and set it up so it stays stable.</p>
          </div>

          <div class="pain-card fade-up d1">
            <div class="pain-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" />
                <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>App pairing takes longer than it should</h3>
            <p>If you can’t get the doorbell into your Wi‑Fi, calibrate motion zones, or connect the chime, you’re left with a “setup in progress” device. We configure everything.</p>
          </div>

          <div class="pain-card fade-up d2">
            <div class="pain-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </div>
            <h3>Deliveries keep slipping through</h3>
            <p>Missed alerts and delayed notifications mean you never see what happened at the door. Proper configuration helps motion detection work when it matters.</p>
          </div>
        </div>

        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>The average homeowner has <em>one “almost set up”</em> doorbell problem.</h2>
            <p>It starts with “just installing it”—then turns into transformer guesses, chime conflicts, and endless app retries. We install and configure so your doorbell is usable right away.</p>
          </div>

          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2">
              <div class="as-num">8s</div>
              <div>
                <div class="as-text-label">average time to enter</div>
                <div class="as-text-sub">An unprotected moment is all it takes.</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d3">
              <div class="as-num">1</div>
              <div>
                <div class="as-text-label">app that actually works</div>
                <div class="as-text-sub">Pairing + training included.</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d4">
              <div class="as-num">$0</div>
              <div>
                <div class="as-text-label">runaround on setup</div>
                <div class="as-text-sub">We finish the job and verify.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- SOLUTION -->
    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img
              class="solve-photo"
              src={heroBg}
              alt="Video doorbell installation outcome"
              loading="lazy"
              width="900"
              height="520"
            />
            <div class="solve-badge">
              <div class="solve-badge-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
                </svg>
              </div>
              <div>
                <div class="solve-badge-num">4.8★</div>
                <div class="solve-badge-label">Doorbell install avg. rating</div>
              </div>
            </div>
          </div>

          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow">THE SOLUTION</div>
            <h2 class="solve-heading">
              Professional install. <em>App-ready.</em>
            </h2>
            <p>We connect you with vetted video doorbell installers in Los Angeles who handle both mounting and setup — wiring checks, app pairing, motion zones, and chime integration.</p>
            <p>You get a walkthrough so you know how to use your doorbell on day one. If anything doesn’t work, we come back and make it right.</p>

            <div class="solve-points">
              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Wiring checks first.</strong> <span>We confirm power options before mounting.</span></div>
              </div>

              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>App setup &amp; training.</strong> <span>Pairing, notifications, and motion zones.</span></div>
              </div>

              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Chime &amp; smart home integration.</strong> <span>Pair the chime and connect devices when applicable.</span></div>
              </div>

              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Clean, professional finish.</strong> <span>Mounting looks right and stays secure.</span></div>
              </div>
            </div>

            <button
              type="button"
              class="btn-primary-gold tvm-book-btn"
              data-open-booking="true"
              data-service={modalService}
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Book Video Doorbell Install Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- SERVICES -->
    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro">
          <div class="section-eyebrow fade-up">VIDEO DOORBELL SERVICES</div>
          <h2 class="section-heading fade-up d1">Everything you need to feel safe.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">
            We handle both the install and the setup so your doorbell works the moment we leave.
          </p>
        </div>

        <div class="services-grid">
          {[
            { title: 'Hardwired Setup', desc: 'Transformer checks, secure wiring, and chime pairing so your doorbell stays powered.' },
            { title: 'Battery Installation', desc: 'Clean mount, stable placement, and battery guidance so you don’t lose notifications.' },
            { title: 'App Pairing & Setup', desc: 'Wi‑Fi pairing, motion zones, recordings, and notification settings configured correctly.' },
            { title: 'Chime Integration', desc: 'Doorbell chime setup so visitors always get heard.' },
            { title: 'Motion Zone Tuning', desc: 'Reduce false alerts with coverage planning and sensitivity tuning.' },
            { title: 'Smart Lock / Integration', desc: 'Coordinate doorbell alerts with your smart home hub when applicable.' },
          ].map((s, i) => (
            <a
              href="#"
              class={`svc-card fade-up ${i === 0 ? 'd1' : i === 1 ? 'd2' : i === 2 ? 'd3' : i === 3 ? 'd4' : i === 4 ? 'd5' : ''}`}
              data-open-quote="true"
              data-service={modalService}
            >
              <div class="svc-card-top">
                <div class="svc-card-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                  </svg>
                </div>
                <h3>{s.title}</h3>
              </div>
              <p>{s.desc}</p>
              <span class="svc-card-link">
                Get a quote
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="process-section">
      <div class="container">
        <div class="process-intro fade-up d1">
          <div class="section-eyebrow">OUR PROCESS</div>
          <h2 class="section-heading fade-up d2">From inquiry to a working doorbell.</h2>
          <p class="section-body fade-up d3" style="margin:0 auto;">Predictable steps so you know what happens next.</p>
        </div>

        <div class="process-steps fade-up d1">
          {[
            { title: 'Tell us your doorbell needs', body: 'Call or request a quote. We’ll confirm the right power and setup approach.' },
            { title: 'We match a vetted installer', body: 'Get an arrival window and a clear quote before any work begins.' },
            { title: 'Install + verify everything', body: 'Mounting, wiring checks, app pairing, and test notifications.' },
            { title: 'Walkthrough + you’re set', body: 'We show you how it works and make sure it’s ready on day one.' },
          ].map((step, i) => (
            <div class="process-step">
              <div class="ps-num">{String(i + 1).padStart(2, '0')}</div>
              <div class="ps-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  {i === 0 ? (
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  ) : i === 1 ? (
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  ) : i === 2 ? (
                    <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  ) : (
                    <path d="M20 6l-11 11-5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  )}
                </svg>
              </div>
              <span class="ps-pill">Step {String(i + 1).padStart(2, '0')}</span>
              <div class="ps-title">{step.title}</div>
              <div class="ps-text">{step.body}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section class="reviews-section">
      <div class="container">
        <div class="reviews-intro">
          <div class="section-eyebrow fade-up">REAL REVIEWS</div>
          <h2 class="section-heading fade-up d1">Trusted for video doorbell installs.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">On time, clean work, and setup you can actually use.</p>
        </div>

        <div class="reviews-grid">
          {testimonials.map((t, i) => (
            <div class={`review-card fade-up ${i === 0 ? 'd1' : i === 1 ? 'd2' : 'd3'}`}>
              <div class="review-stars" aria-hidden="true">★★★★★</div>
              <blockquote class="review-quote">"{t.quote}"</blockquote>
              <div class="review-author">
                <span class="review-initials">{t.initials}</span>
                <div>
                  <strong>{t.author}</strong>
                  <div class="review-source">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Verified customer
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <div class="faq-intro fade-up visible">
          <div class="section-eyebrow">FAQ</div>
          <h2 class="section-heading fade-up d1">Quick answers before you book.</h2>
          <p class="section-body fade-up d2">Everything you need to know about video doorbell installation.</p>
        </div>

        <div class="faq-cols fade-up d1">
          <div class="faq-col">
            {faqs.slice(0, 3).map((f) => (
              <div class="faq-item">
                <button type="button" class="faq-q" aria-expanded="false">
                  {f.q}
                  <span class="faq-icon" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 2v8M2 6h8" stroke-linecap="round" />
                    </svg>
                  </span>
                </button>
                <div class="faq-answer">
                  <p>{f.a}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="faq-col">
            {faqs.slice(3).map((f) => (
              <div class="faq-item">
                <button type="button" class="faq-q" aria-expanded="false">
                  {f.q}
                  <span class="faq-icon" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 2v8M2 6h8" stroke-linecap="round" />
                    </svg>
                  </span>
                </button>
                <div class="faq-answer">
                  <p>{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="container">
        <div class="section-eyebrow">READY TO BOOK</div>
        <h2>Get a doorbell install that just works.</h2>
        <p>Clean setup, app pairing, and a walkthrough so you’re done with troubleshooting.</p>
        <div class="final-cta-btns">
          <button type="button" class="btn-primary-gold" data-open-quote="true" data-service={modalService}>
            <svg width="17" height="17" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
            </svg>
            Get a Free Quote
          </button>
          <a class="btn-ghost-white-final" href={phoneTel} style="color:#ffffff;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call (818) 584-7389
          </a>
        </div>
      </div>
    </section>
  </div>

  <script>
    (function () {
      // Fade-in: add `.visible` when elements enter the viewport.
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) e.target.classList.add('visible');
          });
        },
        { threshold: 0.07, rootMargin: '0px 0px -28px 0px' }
      );

      document.querySelectorAll('.tvm-page .fade-up').forEach(function (el) {
        obs.observe(el);
      });

      // FAQ accordion: toggle `.open` on the clicked FAQ item.
      document.querySelectorAll('.tvm-page .faq-q').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var item = btn.closest('.faq-item');
          if (!item) return;
          var open = item.classList.contains('open');
          document.querySelectorAll('.tvm-page .faq-item.open').forEach(function (i) {
            i.classList.remove('open');
          });
          if (!open) item.classList.add('open');
        });
      });
    })();
  </script>
</BaseLayout>


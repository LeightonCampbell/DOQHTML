---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/tv-mounting-page.css';
import { allServices } from '../../data/servicesData';
import { getServiceLandingContent } from '../../data/serviceLandingData';

const slug = 'bathroom-remodeling';
const serviceItem = allServices.find((s) => s.slug === slug);
const modalService = serviceItem?.label ?? 'Bathroom Remodeling';

const content = getServiceLandingContent(slug, modalService, serviceItem?.description ?? '');
const canonical = `https://www.dealsofquality.com/${content.canonicalPath}/`;

const phoneTel = 'tel:8185847389';
const heroBg = '/images/bathroom-hero.jpg';

const testimonials = [
  {
    quote: 'They handled the waterproofing like pros. No soft spots, no surprises, and the finish looks even better than we imagined.',
    initials: 'LA',
    author: 'Los Angeles, CA',
    rating: 5,
  },
  {
    quote: 'We finally have a bathroom that feels finished. The walkthrough was thorough, and they left everything clean.',
    initials: 'SB',
    author: 'Santa Monica, CA',
    rating: 5,
  },
  {
    quote: 'Our layout is way better now. Tile lines are straight, fixtures are solid, and the whole remodel feels level and secure.',
    initials: 'BH',
    author: 'Beverly Hills, CA',
    rating: 5,
  },
];

const faqs = [
  {
    q: 'How long does a typical bathroom remodel take?',
    a: 'Timelines vary by scope (cosmetic refresh vs. full remodel). We confirm the build plan up front and schedule each phase so your project stays on track.',
  },
  {
    q: 'Do you handle waterproofing correctly?',
    a: 'Yes. Waterproofing is done in the right order before tile and finishes—so your shower walls and floors stay protected for years.',
  },
  {
    q: 'Can you update plumbing during the remodel?',
    a: 'Absolutely. If we see outdated plumbing, leaks, or wrong rough-in placement, we address it during the remodel so your fixtures work properly.',
  },
  {
    q: 'Do you manage permits and code requirements?',
    a: 'Licensed and insured pros handle the work. If permits are required, we make sure everything is done to code before you move forward.',
  },
  {
    q: 'Can you match existing tile or finishes?',
    a: 'We’ll review what you have and help you choose the closest match (or recommend an upgrade if the original material is discontinued).',
  },
  {
    q: 'What happens at the end of the project?',
    a: 'We do a final walkthrough, verify fixtures and finishes, and clean up the work area so you can use the bathroom right away.',
  },
];
---
<BaseLayout title={content.metaTitle} description={content.metaDescription} canonical={canonical}>
  <div class="tvm-page">
    <!-- URGENCY BANNER -->
    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">Same-day bathroom remodel appointments available.</span> Book before noon. <a href={phoneTel}>(818) 584-7389</a></span>
    </div>

    <!-- HERO -->
    <div class="hero-wrap relative overflow-hidden min-h-screen flex flex-col">
      <div
        class="hero-bg-photo absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style={`background-color:#0f172a; background-image: url('${heroBg}'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;`}
      />
      <div class="hero-bg-overlay absolute inset-0 z-[1]" aria-hidden="true"></div>

      <section class="hero-content relative z-[2] flex-1 flex flex-col items-center justify-center py-[90px] pb-20 px-6 text-center" aria-label="Hero">
        <div class="container-max max-w-[1100px] mx-auto px-6">
          <div class="fade-up visible">
            <div class="hero-breadcrumb">
              <a href="/">Home</a><span>›</span>
              <a href="/services/">Services</a><span>›</span>
              Bathroom Remodeling
            </div>

            <div class="hero-service-pill">
              <div class="hero-service-pill-dot"></div>
              BATHROOM REMODELING
            </div>
          </div>

          <h1 class="fade-up d1 visible">
            A bathroom you <br /><em>actually enjoy</em>.
          </h1>
          <p class="hero-sub fade-up d2 visible">
            From waterproofing to fixtures and finishes, we connect you with vetted pros who remodel bathrooms that hold up. Clean workmanship, upfront pricing, and a finish you can feel every time you use it.
          </p>

          <div class="hero-cta-row fade-up d3 visible">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service={modalService}>
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none">
                <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
              </svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href={phoneTel} style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (818) 584-7389
            </a>
          </div>

          <div class="hero-trust-strip fade-up d4 visible">
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor" />
              </svg>
              Vetted remodelers
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
              </svg>
              Licensed &amp; insured
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" />
                <path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
              </svg>
              Same-day availability
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" />
                <path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Clean, durable finish
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3" />
                <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Upfront transparent pricing
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- PAIN -->
    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up visible">
          <div class="section-eyebrow" style="color:#dc2626">THE REAL COST OF WAITING</div>
          <h2 class="section-heading">
            Bathrooms that don’t <em>hold up</em>… cost more later.
          </h2>
          <p class="section-body">
            Leaks, soft flooring, and unfinished corners turn a remodel into ongoing repairs. Waterproofing and build sequencing matter — when they’re guessed, the problem comes back.
          </p>
        </div>

        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Leaks, moisture &amp; poor waterproofing</h3>
            <p>When waterproofing isn’t done in the correct order, water works its way into the structure. You end up re-grouting, re-tiling, or replacing surfaces entirely.</p>
          </div>

          <div class="pain-card fade-up d1">
            <div class="pain-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" />
                <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </div>
            <h3>Outdated layout and cramped storage</h3>
            <p>Bad layout decisions make your bathroom feel smaller than it is. Storage that doesn’t fit, bad circulation, and fixtures placed “by guess” become daily annoyances.</p>
          </div>

          <div class="pain-card fade-up d2">
            <div class="pain-card-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </div>
            <h3>DIY remodels that never feel done</h3>
            <p>Dusty grout lines, uneven tile, and “almost finished” trim work turn the remodel into a project you keep coming back to — instead of enjoying your space.</p>
          </div>
        </div>

        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>The remodel you want is possible <em>with a real build plan.</em></h2>
            <p>Most bathroom delays happen because waterproofing and layout are guessed. We connect you with vetted remodelers who handle demo, plumbing, waterproofing, and finishes in the right sequence — so it stays beautiful.</p>
          </div>

          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2">
              <div class="as-num">4</div>
              <div>
                <div class="as-text-label">stages we do in order</div>
                <div class="as-text-sub">demo, plumbing, waterproofing, finish</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d3">
              <div class="as-num">1</div>
              <div>
                <div class="as-text-label">clean walkthrough</div>
                <div class="as-text-sub">we verify before you sign off</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d4">
              <div class="as-num">$0</div>
              <div>
                <div class="as-text-label">surprises after install</div>
                <div class="as-text-sub">upfront pricing and verification</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- SOLUTION -->
    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img
              class="solve-photo"
              src={heroBg}
              alt="Bathroom remodeling outcome"
              loading="lazy"
              width="900"
              height="520"
            />
            <div class="solve-badge">
              <div class="solve-badge-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
                </svg>
              </div>
              <div>
                <div class="solve-badge-num">4.8★</div>
                <div class="solve-badge-label">Remodel avg. rating</div>
              </div>
            </div>
          </div>

          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow">THE SOLUTION</div>
            <h2 class="solve-heading">
              A remodel built for <em>waterproof durability</em>.
            </h2>
            <p>We connect you with vetted bathroom remodeling pros in Los Angeles who handle waterproofing, fixtures, tile, and finishing — so your bathroom stays solid instead of quietly failing.</p>
            <p>You get a clean walkthrough and clear guidance so you know what’s done, what’s next, and how to keep it looking great.</p>

            <div class="solve-points">
              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Waterproofing first.</strong> <span>Installed in the correct order before tile.</span></div>
              </div>
              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Tile &amp; fixture precision.</strong> <span>Straight lines, level installs, and secure fastening.</span></div>
              </div>
              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Ventilation &amp; finishes.</strong> <span>Proper airflow so moisture doesn’t linger.</span></div>
              </div>
              <div class="solve-point">
                <div class="sp-icon" aria-hidden="true">
                  <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                    <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div class="sp-text"><strong>Clean walkthrough.</strong> <span>We verify everything before you start using it.</span></div>
              </div>
            </div>

            <button type="button" class="btn-primary-gold tvm-book-btn" data-open-booking="true" data-service={modalService}>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Book Bathroom Remodel Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- SERVICES -->
    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro">
          <div class="section-eyebrow fade-up">BATHROOM REMODELING SERVICES</div>
          <h2 class="section-heading fade-up d1">Everything needed for a clean, finished remodel.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">
            We handle the project details so your bathroom looks great and stays that way.
          </p>
        </div>

        <div class="services-grid">
          {[
            { title: 'Vanity & Fixture Install', desc: 'Upgrade sinks, vanities, faucets, and fixtures with secure, level mounting.' },
            { title: 'Tile & Waterproofing', desc: 'Waterproofing and tile work done in the right sequence for lasting protection.' },
            { title: 'Shower & Tub Upgrades', desc: 'New shower/tub installs with clean finishes and proper waterproofing.' },
            { title: 'Flooring Replacement', desc: 'Replace damaged flooring and restore a stable, beautiful surface.' },
            { title: 'Ventilation & Lighting', desc: 'Improve airflow and lighting so moisture doesn’t linger and the space feels bright.' },
            { title: 'Full Remodel Project', desc: 'Design help, build sequencing, and cleanup so you get a finished bathroom.' },
          ].map((s, i) => (
            <a
              href="#"
              class={`svc-card fade-up ${i === 0 ? 'd1' : i === 1 ? 'd2' : i === 2 ? 'd3' : i === 3 ? 'd4' : i === 4 ? 'd5' : ''}`}
              data-open-quote="true"
              data-service={modalService}
            >
              <div class="svc-card-top">
                <div class="svc-card-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                  </svg>
                </div>
                <h3>{s.title}</h3>
              </div>
              <p>{s.desc}</p>
              <span class="svc-card-link">
                Get a quote
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="process-section">
      <div class="container">
        <div class="process-intro fade-up d1">
          <div class="section-eyebrow">OUR PROCESS</div>
          <h2 class="section-heading fade-up d2">From inquiry to a bathroom you can use.</h2>
          <p class="section-body fade-up d3" style="margin:0 auto;">Predictable steps so you know what happens next.</p>
        </div>

        <div class="process-steps fade-up d1">
          {[
            { title: 'Tell us your bathroom needs', body: 'Call or request a quote. We’ll confirm the right scope and waterproofing approach.' },
            { title: 'We match a vetted remodeler', body: 'Get an arrival window and a clear quote before any work begins.' },
            { title: 'Install + waterproof + finish', body: 'Demo, plumbing updates, waterproofing, tile/fixtures, and cleanup.' },
            { title: 'Walkthrough + you’re set', body: 'We verify everything and show you how to keep your new bathroom looking great.' },
          ].map((step, i) => (
            <div class="process-step">
              <div class="ps-num">{String(i + 1).padStart(2, '0')}</div>
              <div class="ps-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  {i === 0 ? (
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  ) : i === 1 ? (
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  ) : i === 2 ? (
                    <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  ) : (
                    <path d="M20 6l-11 11-5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  )}
                </svg>
              </div>
              <span class="ps-pill">Step {String(i + 1).padStart(2, '0')}</span>
              <div class="ps-title">{step.title}</div>
              <div class="ps-text">{step.body}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section class="reviews-section">
      <div class="container">
        <div class="reviews-intro">
          <div class="section-eyebrow fade-up">REAL REVIEWS</div>
          <h2 class="section-heading fade-up d1">Trusted for bathroom remodeling.</h2>
          <p class="section-body fade-up d2" style="margin:0 auto;">Clean work, waterproof results, and a finish you’ll feel.</p>
        </div>

        <div class="reviews-grid">
          {testimonials.map((t, i) => (
            <div class={`review-card fade-up ${i === 0 ? 'd1' : i === 1 ? 'd2' : 'd3'}`}>
              <div class="review-stars" aria-hidden="true">★★★★★</div>
              <blockquote class="review-quote">"{t.quote}"</blockquote>
              <div class="review-author">
                <span class="review-initials">{t.initials}</span>
                <div>
                  <strong>{t.author}</strong>
                  <div class="review-source">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    Verified customer
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <div class="faq-intro fade-up visible">
          <div class="section-eyebrow">FAQ</div>
          <h2 class="section-heading fade-up d1">Quick answers before you book.</h2>
          <p class="section-body fade-up d2">Everything you need to know about bathroom remodeling.</p>
        </div>

        <div class="faq-cols fade-up d1">
          <div class="faq-col">
            {faqs.slice(0, 3).map((f) => (
              <div class="faq-item">
                <button type="button" class="faq-q" aria-expanded="false">
                  {f.q}
                  <span class="faq-icon" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 2v8M2 6h8" stroke-linecap="round" />
                    </svg>
                  </span>
                </button>
                <div class="faq-answer">
                  <p>{f.a}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="faq-col">
            {faqs.slice(3).map((f) => (
              <div class="faq-item">
                <button type="button" class="faq-q" aria-expanded="false">
                  {f.q}
                  <span class="faq-icon" aria-hidden="true">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 2v8M2 6h8" stroke-linecap="round" />
                    </svg>
                  </span>
                </button>
                <div class="faq-answer">
                  <p>{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
      <div class="container">
        <div class="section-eyebrow">READY TO BOOK</div>
        <h2>Get a bathroom remodel that feels right.</h2>
        <p>Waterproofing, fixtures, and a final walkthrough so you’re done with unfinished work.</p>
        <div class="final-cta-btns">
          <button type="button" class="btn-primary-gold" data-open-quote="true" data-service={modalService}>
            <svg width="17" height="17" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" />
            </svg>
            Get a Free Quote
          </button>
          <a class="btn-ghost-white-final" href={phoneTel} style="color:#ffffff;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">

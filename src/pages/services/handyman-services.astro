---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Handyman Services Los Angeles — Deals of Quality';
const description =
  'Professional, thoroughly vetted handyman services in Los Angeles and nationwide. Furniture assembly, repairs, installations, and more. Licensed, insured, 90-day quality guarantee.';
const canonical = 'https://www.dealsofquality.com/services/handyman-services/';

const quoteFormServices = [
  { value: 'general-repairs', label: 'General Home Repairs' },
  { value: 'furniture-assembly', label: 'Furniture Assembly' },
  { value: 'tv-mounting', label: 'TV Mounting & AV Setup' },
  { value: 'light-fixture', label: 'Light Fixture Replacement' },
  { value: 'blinds-curtains', label: 'Blinds & Curtain Rod Install' },
  { value: 'shelving', label: 'Shelving & Storage Installs' },
  { value: 'door-hardware', label: 'Door & Hardware Repairs' },
  { value: 'picture-mirror', label: 'Picture & Mirror Hanging' },
  { value: 'caulking', label: 'Caulking & Weatherproofing' },
  { value: 'other', label: 'Other' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="handyman-main">
    <!-- URGENCY BANNER -->
    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span
        ><span class="urgency-strong">Same-day handyman appointments available today</span> — call before noon.
        <a href="tel:8185847389">(818) 584-7389</a></span
      >
    </div>

    <!-- HERO -->
    <div class="hero-wrap">
      <div
        class="hero-bg"
        style="background-image: url('/images/handyman-hero.jpg'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"
      ></div>
      <section class="hero handyman-hero">
        <div class="container">
          <div class="fade-up">
            <div class="hero-breadcrumb">
              <a href="/">Home</a>
              <span>›</span>
              <a href="/services/">Services</a>
              <span>›</span>
              Handyman Services
            </div>
            <div class="hero-service-pill">
              <div class="hero-service-pill-dot"></div>
              Handyman Services
            </div>
          </div>

          <h1 class="fade-up d1">
            Stop wasting weekends on jobs<br /><em>that never get finished.</em>
          </h1>
          <p class="hero-sub fade-up d2">
            Professional handymen, thoroughly vetted and licensed — ready to handle every repair, assembly, and installation on your list.
            Same-day availability. Upfront, transparent pricing.
          </p>

          <div class="hero-cta-row fade-up d3">
            <button class="btn-primary-gold" data-open-quote="true" data-service="Handyman Services">
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none"
                ><path
                  d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z"
                  fill="currentColor"
                /></svg
              >
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href="tel:8185847389" style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                ><path
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                /></svg
              >
              (818) 584-7389
            </a>
          </div>

          <div class="hero-trust-strip fade-up d4">
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none"
                ><path
                  d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z"
                  fill="currentColor"
                /></svg
              >
              Thoroughly vetted handymen
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none"
                ><path
                  d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linejoin="round"
                /></svg
              >
              Licensed &amp; insured
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none"
                ><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" /><path
                  d="M8 5v3l2 2"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"
                /></svg
              >
              Same-day availability
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none"
                ><path
                  d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z"
                  stroke="currentColor"
                  stroke-width="1.3"
                /><path
                  d="M5.5 8l2 2 3.5-3.5"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                /></svg
              >
              90-day quality guarantee
            </div>
            <div class="hts-item">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none"
                ><rect
                  x="2"
                  y="2"
                  width="12"
                  height="12"
                  rx="2.5"
                  stroke="currentColor"
                  stroke-width="1.3"
                /><path
                  d="M5 8l2 2 4-4"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                /></svg
              >
              Upfront transparent pricing
            </div>
          </div>
        </div>
      </section>
    </div>

    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up">
          <div class="section-eyebrow section-eyebrow--danger">THE REAL COST OF WAITING</div>
          <h2 class="section-heading">
            Small problems have a habit of <em>becoming big ones.</em>
          </h2>
          <p class="section-body">
            You've been meaning to fix that door, hang those shelves, or assemble that furniture for weeks — maybe
            months. Here's what that delay is quietly costing you.
          </p>
        </div>

        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                ><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" /><path
                  d="M12 8v4M12 16h.01"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                /></svg
              >
            </div>
            <h3>Minor repairs silently escalate</h3>
            <p>
              A small cabinet hinge that wobbles. A door that sticks. A towel bar slowly pulling out of the wall. These
              aren't cosmetic problems — they're structural ones waiting to get worse. A $40 repair today becomes a
              $400 wall patch and repaint next year. Deferred maintenance compounds exactly like interest, and the
              interest rate is brutal.
            </p>
          </div>
          <div class="pain-card fade-up d1">
            <div class="pain-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                ><path
                  d="M12 2L4 6v6c0 5 4 9 8 10 4-1 8-5 8-10V6L12 2Z"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linejoin="round"
                /><path
                  d="M9.5 12.5l2 2 4-4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                /></svg
              >
            </div>
            <h3>DIY attempts often double the damage</h3>
            <p>
              YouTube makes it look simple. But a stripped screw anchor, an incorrectly leveled shelf, or a wall mount
              installed into drywall instead of a stud can mean your flat screen ends up on the floor. What started as
              a $0 weekend project turns into a repair bill that includes both the original job and the damage from
              attempting it. The math rarely works out.
            </p>
          </div>
          <div class="pain-card fade-up d2">
            <div class="pain-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                ><path
                  d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                /></svg
              >
            </div>
            <h3>Your time is worth more than you're charging it</h3>
            <p>
              A weekend morning spent wrestling with flat-pack furniture or hunting the right drill bit is time that
              isn't spent on the things that actually matter to you. When you add up the mental load, the frustration,
              and the opportunity cost — hiring a skilled professional often costs less than your own time. And the
              result is guaranteed to be done right.
            </p>
          </div>
        </div>

        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>The average homeowner has <em class="agitate-highlight">6 unfinished home tasks</em> on their list right now.</h2>
            <p>
              That stack of flat-pack boxes. The bathroom shelf still in the hallway. The closet door off its track since you moved in. Each one weighs on you more than you realize — and finding a trustworthy handyman to clear the list shouldn't become its own project. Most people try, get ghosted after an initial quote, and give up. That's exactly what we exist to fix.
            </p>
          </div>
          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2">
              <div class="as-num">67%</div>
              <div>
                <div class="as-text-label">of homeowners delayed a repair that worsened</div>
                <div class="as-text-sub">...and cost significantly more to fix the second time around.</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d3">
              <div class="as-num">4.3h</div>
              <div>
                <div class="as-text-label">average time wasted per failed DIY attempt</div>
                <div class="as-text-sub">Not counting the hardware store trips. Or the emotional cost.</div>
              </div>
            </div>
            <div class="agitate-stat fade-up d4">
              <div class="as-num">$380</div>
              <div>
                <div class="as-text-label">average additional cost from hiring unvetted help</div>
                <div class="as-text-sub">Rework, damage, and redo. The cheapest quote rarely is.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <!-- SOLUTION SECTION -->
    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img
              class="solve-photo"
              src="/images/happy-homeowner.png"
              alt="Happy couple in their home after tasks done right"
              loading="lazy"
            />
            <div class="solve-badge">
              <div class="solve-badge-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"
                  ><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor" /></svg
                >
              </div>
              <div>
                <div class="solve-badge-num">4.8★</div>
                <div class="solve-badge-label">Handyman service avg. rating</div>
              </div>
            </div>
          </div>
          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow section-eyebrow--accent">THE SOLUTION</div>
            <h2 class="solve-heading">One call. Every task done right. <em>Guaranteed.</em></h2>
            <p>
              Deals of Quality handymen aren't random contractors pulled from an app. They're skilled professionals
              who've passed our rigorous vetting process — background checked, license verified, insurance confirmed,
              and reference reviewed. We only work with people we'd trust in our own homes.
            </p>
            <p>
              You tell us what needs doing. We send the right person for the job. They show up on time, work cleanly,
              and leave your home better than they found it. If anything's not right, we come back and fix it — free of
              charge, within 90 days.
            </p>
            <div class="solve-points">
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                    ><path
                      d="M2 7l3 3 7-7"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    /></svg
                  >
                </div>
                <div class="sp-text">
                  <strong>No chasing, no ghosting.</strong> <span>Book online or by phone. We confirm your appointment and follow up with pro details before they arrive.</span>
                </div>
              </div>
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                    ><path
                      d="M2 7l3 3 7-7"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    /></svg
                  >
                </div>
                <div class="sp-text">
                  <strong>One price, no surprises.</strong> <span>Full quote before a single tool is unpacked. What we quote is what you pay — never a penny more without your approval.</span>
                </div>
              </div>
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                    ><path
                      d="M2 7l3 3 7-7"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    /></svg
                  >
                </div>
                <div class="sp-text">
                  <strong>The right person for your job.</strong> <span>Not every handyman is the same. We match the skill set to the task — furniture assembly, mounting, repairs, installations, and more.</span>
                </div>
              </div>
              <div class="solve-point">
                <div class="sp-icon">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                    ><path
                      d="M2 7l3 3 7-7"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    /></svg
                  >
                </div>
                <div class="sp-text">
                  <strong>Your home, left in better shape.</strong> <span>Handymen clean up after themselves. No mess, no leftover materials, no damage. Just finished work you're proud of.</span>
                </div>
              </div>
            </div>
            <button type="button" class="btn-primary-gold" style="display:inline-flex;width:auto;" data-open-booking="true" data-service="Handyman">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
                ><path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                /></svg
              >
              Book a Handyman Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- SERVICES (9 cards) -->
    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">WHAT WE HANDLE</div>
          <h2 class="section-heading section-heading--no-em">Everything on your list. Nothing left undone.</h2>
          <p class="section-body">
            Our handymen handle a wide range of tasks – from the quick fixes you've been putting off to the bigger jobs that need a skilled hand. If it's around the house, we can handle it.
          </p>
        </div>
        <div class="services-grid">
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              </div>
              <h3>Furniture Assembly</h3>
            </div>
            <p>IKEA, Wayfair, West Elm — no matter where it came from or how many bags of hardware it arrived with. We assemble it correctly, level it properly, and dispose of the packaging.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              </div>
              <h3>TV Mounting &amp; AV Setup</h3>
            </div>
            <p>Clean wall mount installation with wires hidden behind the wall for a truly finished look. We find the studs, use the correct hardware, and make sure your TV is perfectly level and safely secured.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3>Shelving &amp; Storage Installs</h3>
            </div>
            <p>From floating shelves to full closet systems — properly anchored, perfectly level, rated to actually hold what you need to store. No wobble, no future surprises.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              </div>
              <h3>Door &amp; Hardware Repairs</h3>
            </div>
            <p>Sticking doors, broken hinges, faulty handles, misaligned latches — we diagnose the root cause and fix it properly so the problem doesn't come back in two weeks. Cabinet hardware, closet doors, exterior doors, screen doors.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
              <h3>Picture &amp; Mirror Hanging</h3>
            </div>
            <p>Heavy mirrors and gallery walls done right. We use the correct wall anchors for your wall type, ensure every piece is level, and protect your walls from damage during installation.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3>Caulking &amp; Weatherproofing</h3>
            </div>
            <p>Windows, doors, and bathroom seals that are cracked or falling let in air, moisture, and pests. We strip old caulk cleanly, prep the surface properly, and apply a clean professional bead that seals correctly and lasts.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01"/></svg>
              </div>
              <h3>Blinds &amp; Curtain Rod Install</h3>
            </div>
            <p>Perfectly level, properly anchored, and looking the way they looked on the product page. No tilted brackets, no stripped screws, no daylight gaps where there shouldn't be any. Your windows, done properly.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Handyman Services" role="button">
            <div class="service-card-top">
              <div class="service-icon-wrap">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
              </div>
              <h3>Light Fixture Replacement</h3>
            </div>
            <p>Swapping out an old fixture for a new one you love — done safely, cleanly, and to code. Ceiling fans, pendant lights, bathroom vanity lights, and more. We test everything before we leave.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>

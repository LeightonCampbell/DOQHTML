  <script define:vars={{ quoteFormServices }}>
    /* Scroll animations */
    const obs = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.07, rootMargin: '0px 0px -28px 0px' }
    );
    document.querySelectorAll('.fade-up').forEach((el) => obs.observe(el));

    /* Animated counters */
    function animateCounter(el) {
      const target = parseFloat(el.dataset.target);
      const decimals = parseInt(el.dataset.decimal || '0');
      const suffix = el.dataset.suffix || '';
      const duration = 1800;
      const start = performance.now();
      function step(now) {
        const p = Math.min((now - start) / duration, 1);
        const e = 1 - Math.pow(1 - p, 3);
        el.textContent = decimals ? (e * target).toFixed(decimals) + suffix : Math.floor(e * target).toLocaleString() + suffix;
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = decimals ? target.toFixed(decimals) + suffix : target.toLocaleString() + suffix;
      }
      requestAnimationFrame(step);
    }
    const counterObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.querySelectorAll('.counter').forEach(animateCounter);
            counterObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    document.querySelectorAll('.stats-strip').forEach((el) => counterObs.observe(el));

    /* FAQ accordion */
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const open = item.classList.contains('open');
        document.querySelectorAll('.faq-item.open').forEach((i) => i.classList.remove('open'));
        if (!open) item.classList.add('open');
      });
    });

    /* In-place quote form (same flow as quote modal): 3 steps, progress 1–2–3, submit to /api/send-email */
    function scrollToQuote(e) {
      if (e && e.preventDefault) e.preventDefault();
      const el = document.getElementById('quote');
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    window.scrollToQuote = scrollToQuote;

    /* Urgency banner: transition from top to bottom after 150px scroll */
    (function() {
      var banner = document.querySelector('.urgency-banner');
      if (!banner) return;
      var moved = false;
      window.addEventListener('scroll', function() {
        if (!moved && window.scrollY > 150) {
          moved = true;
          banner.classList.add('hm-banner-fading');
          setTimeout(function() {
            banner.classList.add('hm-banner-bottom');
            banner.classList.remove('hm-banner-fading');
          }, 260);
        }
      }, { passive: true });
    })();

    document.addEventListener('DOMContentLoaded', function () {
      const serviceList = typeof quoteFormServices !== 'undefined' ? quoteFormServices : [];
      let currentStep = 1;

      function setHqStep(step) {
        currentStep = step;
        [1, 2].forEach((i) => {
          const el = document.getElementById('hq-step-' + i);
          if (el) el.classList.toggle('active', i === step);
        });
        document.querySelectorAll('.quote-form-wrap .progress-step').forEach((el, i) => {
          el.classList.remove('active', 'done');
          const dot = el.querySelector('.ps-dot');
          if (!dot) return;
          if (i + 1 < step) {
            el.classList.add('done');
            dot.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          } else {
            dot.textContent = i + 1;
            if (i + 1 === step) el.classList.add('active');
          }
        });
      }

      function showSubmitError(msg) {
        const el = document.getElementById('form-submit-error');
        if (el) { el.textContent = msg; el.style.display = 'block'; el.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
      }
      function hideSubmitError() {
        const el = document.getElementById('form-submit-error');
        if (el) { el.style.display = 'none'; el.textContent = ''; }
      }

      function renderSuggestions(val) {
        const listbox = document.getElementById('hq-service-suggestions');
        if (!listbox) return;
        const v = (val || '').trim().toLowerCase();
        listbox.innerHTML = '';
        const added = {};
        serviceList.forEach((s) => {
          const label = (s.label || s.value || '').trim();
          if (!label || added[label]) return;
          if (!v || label.toLowerCase().indexOf(v) !== -1) {
            added[label] = true;
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.role = 'option';
            btn.className = 'hq-suggestion-option';
            btn.textContent = label;
            btn.dataset.value = label;
            listbox.appendChild(btn);
          }
        });
        if (v && Object.keys(added).length === 0) {
          const trimmed = (val || '').trim().slice(0, 80);
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.role = 'option';
          btn.className = 'hq-suggestion-option hq-suggestion-use';
          btn.textContent = 'Use "' + trimmed + (trimmed.length >= 80 ? '…' : '') + '"';
          btn.dataset.value = (val || '').trim();
          listbox.appendChild(btn);
        }
        listbox.classList.toggle('hidden', listbox.children.length === 0);
      }

      const serviceInput = document.getElementById('hq-service-input');
      const suggestionsEl = document.getElementById('hq-service-suggestions');
      const hiddenService = document.getElementById('hq-hidden-service');
      const otherWrap = document.getElementById('hq-other-wrap');
      const otherInput = document.getElementById('hq-service-other');
      function toggleOtherField() {
        const isOther = (serviceInput && serviceInput.value.trim().toLowerCase()) === 'other';
        if (otherWrap) otherWrap.style.display = isOther ? 'block' : 'none';
        if (!isOther && otherInput) otherInput.value = '';
      }
      if (serviceInput && suggestionsEl) {
        serviceInput.addEventListener('focus', () => renderSuggestions(serviceInput.value));
        serviceInput.addEventListener('input', () => {
          renderSuggestions(serviceInput.value);
          if (hiddenService) hiddenService.value = serviceInput.value.trim();
          toggleOtherField();
        });
        serviceInput.addEventListener('blur', () => setTimeout(() => suggestionsEl.classList.add('hidden'), 180));
        suggestionsEl.addEventListener('mousedown', (e) => {
          const opt = e.target.closest('button[role="option"]');
          if (opt && opt.dataset.value !== undefined) {
            e.preventDefault();
            serviceInput.value = opt.dataset.value;
            if (hiddenService) hiddenService.value = opt.dataset.value;
            suggestionsEl.classList.add('hidden');
            suggestionsEl.innerHTML = '';
            toggleOtherField();
            if (opt.dataset.value === 'Other' && otherInput) setTimeout(() => otherInput.focus(), 100);
          }
        });
      }

      const zipInput = document.getElementById('hq-zip');
      const zipErr = document.getElementById('hq-zip-error');
      if (zipInput) {
        zipInput.addEventListener('input', function () {
          this.value = this.value.replace(/\D/g, '').slice(0, 5);
          if (zipErr) { zipErr.classList.add('hidden'); zipErr.textContent = ''; }
        });
      }

      const form = document.getElementById('handyman-quote-form');
      if (!form) return;

      form.addEventListener('click', function (e) {
        const nextBtn = e.target.closest('.hq-next[data-hq-goto]');
        const backBtn = e.target.closest('.hq-back[data-hq-goto]');
        if (nextBtn) {
          e.preventDefault();
          const goto = parseInt(nextBtn.getAttribute('data-hq-goto'), 10);
          if (goto === 2) {
            if (!serviceInput || !serviceInput.value.trim()) {
              const err = document.getElementById('form-step-error');
              if (err) { err.textContent = 'Please enter a service.'; err.style.display = 'block'; }
              return;
            }
            if (hiddenService) hiddenService.value = serviceInput.value.trim();
            const isOther = serviceInput.value.trim() === 'Other';
            if (isOther && otherInput && !otherInput.value.trim()) {
              const err = document.getElementById('form-step-error');
              if (err) { err.textContent = 'Please describe your service need when "Other" is selected.'; err.style.display = 'block'; }
              return;
            }
            const zipVal = zipInput && zipInput.value.replace(/\D/g, '');
            if (!zipVal || zipVal.length !== 5) {
              if (zipErr) { zipErr.textContent = 'Please enter a 5-digit ZIP code.'; zipErr.classList.remove('hidden'); }
              return;
            }
            const zipNum = parseInt(zipVal, 10);
            if (zipNum < 501 || zipNum > 99950) {
              if (zipErr) { zipErr.textContent = 'Please enter a valid US ZIP code (00501–99950).'; zipErr.classList.remove('hidden'); }
              return;
            }
            if (zipErr) { zipErr.classList.add('hidden'); zipErr.textContent = ''; }
            const err1 = document.getElementById('form-step-error');
            if (err1) { err1.style.display = 'none'; err1.textContent = ''; }
          }
          setHqStep(goto);
          return;
        }
        if (backBtn) {
          e.preventDefault();
          setHqStep(parseInt(backBtn.getAttribute('data-hq-goto'), 10));
        }
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        hideSubmitError();
        const name = (document.getElementById('hq-name') && document.getElementById('hq-name').value) || '';
        const email = (document.getElementById('hq-email') && document.getElementById('hq-email').value) || '';
        const phone = (document.getElementById('hq-phone') && document.getElementById('hq-phone').value) || '';
        if (!name.trim() || !email.trim() || !phone.trim()) {
          showSubmitError('Please fill in your name, email, and phone number.');
          return;
        }
        const service = (hiddenService && hiddenService.value) || serviceInput?.value?.trim() || 'Handyman Services';
        const zip = (zipInput && zipInput.value.replace(/\D/g, '').slice(0, 5)) || '';
        const urgencyRadio = form.querySelector('input[name="hq-urgency"]:checked');
        const details = (document.getElementById('hq-details') && document.getElementById('hq-details').value) || '';
        const serviceOther = (otherInput && otherInput.value && otherInput.value.trim()) || '';
        const payload = {
          formType: 'booking',
          name: name.trim(),
          email: email.trim(),
          phone: phone.trim(),
          service,
          zip,
          preferredTiming: (urgencyRadio && urgencyRadio.value) || undefined,
          details: details.trim() || undefined,
        };
        if (service === 'Other' && serviceOther) payload.serviceOther = serviceOther;
        const submitBtn = document.getElementById('form-submit-btn');
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }
        fetch('/api/send-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }).then(function (res) {
          if (res.ok) {
            document.getElementById('form-wrap').style.display = 'none';
            document.getElementById('form-success').style.display = 'block';
            document.querySelector('.quote-form-wrap .progress-wrap').style.display = 'none';
          } else {
            return res.json().catch(() => ({})).then((err) => {
              showSubmitError(err.error || err.message || 'Something went wrong. Please try again or call us.');
            });
          }
        }).catch(function () {
          showSubmitError('Something went wrong. Please try again or call us.');
        }).finally(function () {
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Get Free Quote'; }
        });
      });
    });
  </script>


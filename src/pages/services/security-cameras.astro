---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Security Camera Installation Los Angeles — Deals of Quality';
const description = 'Professional security camera installation in Los Angeles. Indoor, outdoor, video doorbell, multi-camera systems, smart locks, and more. Vetted installers. Upfront pricing.';
const canonical = 'https://www.dealsofquality.com/services/security-cameras/';

const quoteFormServices = [
  { value: 'indoor-camera', label: 'Indoor Camera Installation' },
  { value: 'outdoor-camera', label: 'Outdoor Camera Installation' },
  { value: 'video-doorbell', label: 'Video Doorbell Setup' },
  { value: 'multi-camera', label: 'Multi-Camera System' },
  { value: 'dvr-nvr', label: 'DVR / NVR Setup & Configuration' },
  { value: 'smart-lock', label: 'Smart Lock Installation' },
  { value: 'floodlight-camera', label: 'Floodlight Camera Install' },
  { value: 'motion-sensor', label: 'Motion Sensor Setup' },
  { value: 'other', label: 'Other' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="security-cameras-main">

    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">Same-day security camera installation available.</span> Book before noon. <a href="tel:8185847389">(818) 584-7389</a></span>
    </div>

    <div class="hero-wrap relative overflow-hidden min-h-screen flex flex-col">
      <div class="hero-bg-photo absolute inset-0 z-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/security-camera-hero.jpg'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"></div>
      <div class="hero-bg-overlay absolute inset-0 z-[1]" aria-hidden="true"></div>
      <section class="hero-content relative z-[2] flex-1 flex flex-col items-center justify-center py-[90px] pb-20 px-6 text-center" aria-label="Hero">
        <div class="container-max max-w-[1100px] mx-auto px-6">
          <div class="fade-up">
            <div class="hero-breadcrumb">
              <a href="/">Home</a><span>›</span><a href="/services/">Services</a><span>›</span>Security Cameras
            </div>
            <div class="hero-service-pill"><div class="hero-service-pill-dot"></div>Security Camera Installation</div>
          </div>
          <h1 class="fade-up d1">Your home, protected.<br /><em>Every angle covered.</em></h1>
          <p class="hero-sub fade-up d2">Professional security camera installation in Los Angeles — indoor, outdoor, video doorbells, and full systems. Vetted installers, upfront pricing, every system tested before we leave.</p>
          <div class="hero-cta-row fade-up d3">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="Security Cameras">
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"/></svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href="tel:8185847389" style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (818) 584-7389
            </a>
          </div>
          <div class="hero-trust-strip fade-up d4">
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor"/></svg>Background-checked installers</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>Every system tested before we leave</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Same-day availability</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>All major brands supported</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>Upfront transparent pricing</div>
          </div>
        </div>
      </section>
    </div>

    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up">
          <div class="section-eyebrow section-eyebrow--danger">WHY MOST HOMES ARE STILL VULNERABLE</div>
          <h2 class="section-heading">A break-in takes 8 seconds. <em>An unprotected home gives thieves all they need.</em></h2>
          <p class="section-body">Most homeowners know they should have cameras. Here's why waiting — or going DIY — leaves you more exposed than you think.</p>
        </div>
        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <h3>Break-ins happen in seconds — without footage, there's no record</h3>
            <p>The FBI reports a burglary every 25 seconds in the US. In Los Angeles, porch piracy and vehicle break-ins are rampant. Without cameras, you have no record for insurance claims, no description for police, and no deterrence for the next attempt. Properties with visible cameras are significantly less likely to be targeted in the first place.</p>
          </div>
          <div class="pain-card fade-up d1">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <h3>DIY installs have blind spots and drop offline constantly</h3>
            <p>A camera mounted at the wrong angle covers a wall instead of an entry point. A wireless camera with poor signal drops recordings exactly when something happens. Overlapping fields of view create false security — you see most of your property, but "most" isn't the same as "all." Professional installers plan coverage, handle mounting challenges, and configure systems so they stay online reliably.</p>
          </div>
          <div class="pain-card fade-up d2">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>Cheap cameras fail when you need them most</h3>
            <p>Budget cameras compress footage so heavily that face and license plate recognition becomes impossible. They fail in rain. They miss events in low light. Their apps stop working after firmware updates the manufacturer stops supporting. When an incident happens, you need footage that's actually usable — not a blurry recording that your insurance company can't act on.</p>
          </div>
        </div>
        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>Over <em class="agitate-highlight">60% of convicted burglars</em> said they would avoid a home with security cameras entirely.</h2>
            <p>Visible, well-placed cameras don't just record — they prevent. A correctly installed outdoor camera at the front door and driveway is one of the highest-ROI security investments a homeowner can make. The deterrence effect alone is worth it.</p>
          </div>
          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2"><div class="as-num">60%</div><div><div class="as-text-label">of burglars avoid homes with visible cameras</div><div class="as-text-sub">Cameras prevent crime, not just record it.</div></div></div>
            <div class="agitate-stat fade-up d3"><div class="as-num">8s</div><div><div class="as-text-label">average time for a burglar to enter an unlocked door</div><div class="as-text-sub">They move fast. Your cameras need to cover entry points.</div></div></div>
            <div class="agitate-stat fade-up d4"><div class="as-num">$2,661</div><div><div class="as-text-label">average loss per residential burglary incident</div><div class="as-text-sub">Camera installation costs a fraction of that — once.</div></div></div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img class="solve-photo" src="/images/security-cameras-solotion.jpg" alt="Professional security camera installation in Los Angeles" loading="lazy" />
            <div class="solve-badge">
              <div class="solve-badge-icon"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"/></svg></div>
              <div><div class="solve-badge-num">4.8★</div><div class="solve-badge-label">Security install avg. rating</div></div>
            </div>
          </div>
          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow section-eyebrow--accent">THE SOLUTION</div>
            <h2 class="solve-heading">Professional install. Real coverage. <em>Monitor from anywhere using your smart phone.</em></h2>
            <p>Deals of Quality connects you with vetted security camera installers in Los Angeles who know coverage planning — not just cable runs. They assess your property, identify entry points and blind spots, and install your system to actually protect it.</p>
            <p>Every system is configured, app-connected, and tested before the installer leaves. You get a walkthrough so you know exactly how to use it. And if anything isn't right, we come back and fix it.</p>
            <div class="solve-points">
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Coverage planning, not just camera mounting.</strong> <span>We map your entry points, identify blind spots, and position cameras for maximum coverage — not just wherever is easiest to mount.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>All major brands installed and configured.</strong> <span>Ring, Arlo, Nest, Reolink, Hikvision, Dahua, Lorex — we work with what you have or recommend the right system for your needs.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Fully configured before we leave.</strong> <span>App setup, motion zones, recording schedules, notifications — everything set up and tested so your system works the moment we walk out the door.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Background-checked installers you can trust in your home.</strong> <span>Everyone we send has passed a comprehensive background check. You're not opening your home to a stranger from an app — you're trusting a vetted professional.</span></div></div>
            </div>
            <button type="button" class="btn-primary-gold" style="display:inline-flex;width:auto;" data-open-booking="true" data-service="Security Cameras">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Book Security Camera Install Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">SECURITY SERVICES WE INSTALL</div>
          <h2 class="section-heading section-heading--no-em">Every type of home security we handle.</h2>
          <p class="section-body">From a single video doorbell to a full multi-camera system with smart locks and motion sensors — our installers handle the full range of residential security in Los Angeles.</p>
        </div>
        <div class="services-grid">
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l-4 4L9 12M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><h3>Indoor Camera Installation</h3></div>
            <p>Ceiling and wall-mount indoor cameras covering living areas, entryways, nurseries, and valuables. Positioned to avoid blind spots, connected to your app, and configured with the right motion sensitivity to catch what matters — without constant false alerts.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg></div><h3>Outdoor Camera Installation</h3></div>
            <p>Weatherproof cameras covering driveways, backyards, side yards, and all exterior entry points. We assess your property's layout, choose the right mounting heights and angles, and run cables cleanly and discreetly for a professional finish.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div><h3>Video Doorbell Setup</h3></div>
            <p>Ring, Nest Hello, Arlo, Eufy, and all major doorbell brands — installed, wired or battery-configured, app-connected, and motion zones set correctly. We ensure your existing doorbell wiring supports the unit you choose and handle any transformer upgrades required.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div><h3>Multi-Camera System</h3></div>
            <p>4, 8, or 16-camera systems covering every angle of your property. We design coverage before installation to eliminate blind spots, run cabling neatly, set up centralized recording, and configure remote viewing from a single app on your phone.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 7h.01M7 12h.01M7 17h.01M11 7h6M11 12h6M11 17h6"/></svg></div><h3>DVR / NVR Setup & Configuration</h3></div>
            <p>DVR and NVR setup for existing or new wired camera systems. Hard drive installation, recording schedules, motion-triggered recording, remote access configuration, and user account setup — so you can access footage anywhere, any time.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg></div><h3>Smart Lock Installation</h3></div>
            <p>Keypad, fingerprint, and app-controlled smart lock installation for front door, back door, and garage. We handle the mechanical installation, app configuration, user codes setup, and integration with your existing security system where applicable.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></div><h3>Floodlight Camera Install</h3></div>
            <p>Motion-activated floodlight cameras for driveways, backyards, and side gates. We hardwire to an existing exterior outlet or junction box, set motion sensitivity zones, configure the camera recording, and ensure adequate field of view coverage.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Security Cameras" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div><h3>Motion Sensor Setup</h3></div>
            <p>PIR and dual-tech motion sensors for interior rooms, hallways, garages, and entry zones. Paired with smart home hubs or standalone alarm systems — we position sensors to eliminate dead zones, calibrate sensitivity, and configure alerts that fire when they should and don't when they shouldn't.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="process-section">
      <div class="container">
        <div class="process-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">OUR PROCESS</div>
          <h2 class="section-heading section-heading--no-em">From your first inquiry to a fully working security system — here's how it happens.</h2>
          <p class="section-body">No mystery, no guesswork. Every step is predictable and designed around getting you a system that works.</p>
        </div>
        <div class="process-grid fade-up">
          <div class="process-card">
            <span class="process-num">01</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
            <span class="process-pill">Step 01</span>
            <h3>Tell us about your property</h3>
            <p>Fill out the quote form or call (818) 584-7389. Tell us how many cameras, what areas need coverage, and what system you have (or want). We'll confirm details and provide an upfront price.</p>
          </div>
          <div class="process-card">
            <span class="process-num">02</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <span class="process-pill">Step 02</span>
            <h3>We match a vetted installer</h3>
            <p>We match your job to a background-checked security installer with experience on your system type. You get their credentials, an arrival window, and a confirmed flat-rate quote before any work starts.</p>
          </div>
          <div class="process-card">
            <span class="process-num">03</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <span class="process-pill">Step 03</span>
            <h3>Site walk & installation</h3>
            <p>Your installer walks the property, confirms camera positions and coverage plan, and installs everything cleanly. Cables are routed discreetly. Mounting is secure. No visible mess when the job is done.</p>
          </div>
          <div class="process-card">
            <span class="process-num">04</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg></div>
            <span class="process-pill">Step 04</span>
            <h3>Configured, tested, and handed over.</h3>
            <p>Every camera is live. App is set up. Alerts are configured. We test every angle and walk you through the system so you know how to use it. You leave with a fully working security system — not a to-do list.</p>
          </div>
        </div>
      </div>

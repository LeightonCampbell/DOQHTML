---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Plumbing Services Los Angeles — Deals of Quality';
const description = 'Licensed plumbing services in Los Angeles. Drain cleaning, leak repair, water heater replacement, pipe repair, and more. Upfront pricing, same-day availability.';
const canonical = 'https://www.dealsofquality.com/services/plumbing/';

const quoteFormServices = [
  { value: 'drain-cleaning', label: 'Drain Cleaning' },
  { value: 'leak-repair', label: 'Leak Detection & Repair' },
  { value: 'toilet-repair', label: 'Toilet Repair / Replacement' },
  { value: 'faucet-install', label: 'Faucet & Fixture Installation' },
  { value: 'water-heater-repair', label: 'Water Heater Repair' },
  { value: 'water-heater-replace', label: 'Water Heater Replacement' },
  { value: 'garbage-disposal', label: 'Garbage Disposal Install' },
  { value: 'pipe-repair', label: 'Pipe Repair & Replacement' },
  { value: 'shower-tub', label: 'Shower & Tub Repair' },
  { value: 'other', label: 'Other' },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="plumbing-main">

    <div class="urgency-banner">
      <div class="urgency-dot"></div>
      <span><span class="urgency-strong">Plumbing emergency? Available same-day.</span> Call now: <a href="tel:8185847389">(818) 584-7389</a></span>
    </div>

    <div class="hero-wrap">
      <div class="hero-bg" style="background-image: url('/images/plumbing-hero.jpg'); background-position: center 40%; background-size: cover; background-repeat: no-repeat;"></div>
      <section class="hero plumbing-hero">
        <div class="container">
          <div class="fade-up">
            <div class="hero-breadcrumb">
              <a href="/">Home</a><span>›</span><a href="/services/">Services</a><span>›</span>Plumbing
            </div>
            <div class="hero-service-pill"><div class="hero-service-pill-dot"></div>Plumbing Services</div>
          </div>
          <h1 class="fade-up d1">Plumbing problems fixed right.<br /><em>The first time.</em></h1>
          <p class="hero-sub fade-up d2">Licensed plumbers in Los Angeles — drain clogs, leaks, water heaters, pipe repair, and more. Same-day service. Upfront flat-rate pricing. No surprises.</p>
          <div class="hero-cta-row fade-up d3">
            <button type="button" class="btn-primary-gold" data-open-quote="true" data-service="Plumbing">
              <svg width="17" height="17" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"/></svg>
              Get a Free Quote
            </button>
            <a class="btn-ghost-white" href="tel:8185847389" style="color:#ffffff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (818) 584-7389
            </a>
          </div>
          <div class="hero-trust-strip fade-up d4">
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5H13l-3 2 1 3.5L8 8.5 5 10l1-3.5-3-2h3.5L8 1Z" fill="currentColor"/></svg>Licensed & insured plumbers</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>Upfront flat-rate pricing</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Same-day emergency service</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M8 1L2 4v4c0 3 2.5 5.5 6 6.5 3.5-1 6-3.5 6-6.5V4L8 1Z" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 8l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>Work guaranteed</div>
            <div class="hts-item"><svg width="15" height="15" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>No overtime charges</div>
          </div>
        </div>
      </section>
    </div>

    <section class="pain-section">
      <div class="container">
        <div class="pain-intro fade-up">
          <div class="section-eyebrow section-eyebrow--danger">WHY PLUMBING ISSUES COST MORE WHEN IGNORED</div>
          <h2 class="section-heading">A minor leak today is a <em>major water bill tomorrow.</em></h2>
          <p class="section-body">Every plumbing issue gets worse with time. Here's what delaying a repair quietly does to your home — and your wallet.</p>
        </div>
        <div class="pain-grid">
          <div class="pain-card fade-up">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0L12 2.69z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>Small leaks become expensive water damage</h3>
            <p>A pinhole leak in a wall or under a slab wastes hundreds of gallons before you notice your water bill spike. By the time you call a plumber, the leak has often soaked into framing, drywall, or subfloor — turning a $150 repair into a multi-thousand-dollar remediation. Don't wait to find out which yours is.</p>
          </div>
          <div class="pain-card fade-up d1">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <h3>DIY plumbing mistakes flood your home</h3>
            <p>That tutorial made it look easy. But overtightened fittings crack under pressure. Wrong thread tape fails at the worst moment. Mismatched pipe materials corrode each other for years before giving out. Plumbing connects every room in your home — the consequences of a wrong move travel fast, and water damage is never covered by the homeowner who caused it.</p>
          </div>
          <div class="pain-card fade-up d2">
            <div class="pain-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9.5 12.5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>Unvetted plumbers overcharge and underdeliver</h3>
            <p>The first plumber who answers a late-night emergency call has no incentive to price fairly. Without upfront quotes, it's easy to get charged by the hour for work that should be a flat rate. Worse, a repair done without permits or with cut-rate parts can fail home inspections, void homeowner's insurance, or simply break again in 6 months.</p>
          </div>
        </div>
        <div class="agitate-block fade-up d1">
          <div class="agitate-text">
            <h2>The average plumbing leak goes <em class="agitate-highlight">undetected for 70+ days</em> before the homeowner notices.</h2>
            <p>Most leaks aren't dramatic — a dripping pipe inside a wall, a slow toilet flapper, a failing supply line under a cabinet. By the time it's visible, it's already caused damage. The sooner you have a pro assess your plumbing, the more affordable the fix.</p>
          </div>
          <div class="agitate-stats">
            <div class="agitate-stat fade-up d2"><div class="as-num">70+</div><div><div class="as-text-label">days the average hidden leak goes undetected</div><div class="as-text-sub">Water damage compounds daily.</div></div></div>
            <div class="agitate-stat fade-up d3"><div class="as-num">$2,400</div><div><div class="as-text-label">average cost of water damage repair per incident</div><div class="as-text-sub">A $150 repair ignored becomes thousands.</div></div></div>
            <div class="agitate-stat fade-up d4"><div class="as-num">10%</div><div><div class="as-text-label">of US homes have leaks wasting 90+ gallons daily</div><div class="as-text-sub">That's on your water bill every month.</div></div></div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider--cream"></div>

    <section class="solve-section">
      <div class="container">
        <div class="solve-grid">
          <div class="solve-photo-col fade-up">
            <img class="solve-photo" src="/images/plumbing-solution.jpg" alt="Licensed plumber completing a repair in Los Angeles" loading="lazy" />
            <div class="solve-badge">
              <div class="solve-badge-icon"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2 5h5l-4 3 1.5 5L10 12 5.5 15 7 10 3 7h5L10 2Z" fill="currentColor"/></svg></div>
              <div><div class="solve-badge-num">4.8★</div><div class="solve-badge-label">Plumbing avg. rating</div></div>
            </div>
          </div>
          <div class="solve-copy fade-up d1">
            <div class="section-eyebrow section-eyebrow--accent">THE SOLUTION</div>
            <h2 class="solve-heading">Licensed plumbers. Flat-rate quotes. <em>Problem solved.</em></h2>
            <p>Deals of Quality connects you with licensed, vetted plumbers in Los Angeles who show up on time, diagnose the problem accurately, and fix it right — without padding the bill with unnecessary extras.</p>
            <p>You get a full, upfront quote before any work starts. No hourly surprises. No upselling you don't need. Just reliable work, backed by a guarantee on every job.</p>
            <div class="solve-points">
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Same-day and emergency service available.</strong> <span>Burst pipe at midnight? Toilet backup before guests arrive? We have plumbers available when you need them.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Flat-rate pricing, quoted before work begins.</strong> <span>You know the total cost before we touch a pipe. No "I'll let you know when I'm done" billing.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Licensed and insured in California.</strong> <span>Every plumber we send is properly licensed, carries general liability insurance, and knows local code.</span></div></div>
              <div class="solve-point"><div class="sp-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="sp-text"><strong>Guaranteed work, no callbacks on us.</strong> <span>If the repair fails within our warranty period, we come back and make it right. At no additional cost.</span></div></div>
            </div>
            <button type="button" class="btn-primary-gold" style="display:inline-flex;width:auto;" data-open-booking="true" data-service="Plumbing">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Book Plumbing Service Today
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="services-section" id="services">
      <div class="container">
        <div class="services-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">PLUMBING SERVICES</div>
          <h2 class="section-heading section-heading--no-em">Every plumbing problem we solve.</h2>
          <p class="section-body">From slow drains to full water heater replacements, our licensed plumbers handle the full range of residential plumbing issues in Los Angeles.</p>
        </div>
        <div class="services-grid">
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0L12 2.69z"/></svg></div><h3>Drain Cleaning</h3></div>
            <p>Slow or fully blocked drains in kitchen, bathroom, or laundry. We clear clogs using professional-grade snaking and hydro-jetting — not just pushing the blockage deeper. Grease, hair, tree roots, mineral buildup — all of it.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 8v4M12 16h.01"/></svg></div><h3>Leak Detection & Repair</h3></div>
            <p>Wall leaks, slab leaks, under-sink drips, and hidden supply line failures. We locate leaks accurately before opening walls — reducing unnecessary demolition. Precise diagnosis, permanent repairs, documented work.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12h12M6 6h12M6 18h12"/></svg></div><h3>Toilet Repair & Replacement</h3></div>
            <p>Running toilets, phantom flushes, cracked bowls, loose bases, and full replacements. A running toilet can waste 200 gallons a day. We fix the cause — not just the symptom — and replace when repair isn't worth it.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div><h3>Faucet & Fixture Installation</h3></div>
            <p>Kitchen and bathroom faucet replacement, showerhead upgrades, valve replacements, and supply line swaps. Whether it's a dripping faucet or a full fixture upgrade, we install clean, leak-free, and to code.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="4"/></svg></div><h3>Water Heater Repair</h3></div>
            <p>Pilot light failures, thermostat issues, pressure relief valve problems, sediment buildup, and anode rod replacement. We diagnose water heater issues quickly and repair when it makes financial sense.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/></svg></div><h3>Water Heater Replacement</h3></div>
            <p>Tank and tankless water heater replacement. When repair isn't worth the investment, we swap your unit fast — properly permitted, correctly sized, and with all new supply and discharge lines installed to code.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M16.9 16.9l1.41 1.41M4.93 4.93l1.41 1.41M7.1 16.9l-1.41 1.41M2 12h3M19 12h3M12 2v3M12 19v3"/></svg></div><h3>Garbage Disposal Install</h3></div>
            <p>New garbage disposal installation or replacement of failed units. We match the right horsepower to your kitchen, hardwire or plug-in depending on your setup, and test for leaks and proper operation before we leave.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d1" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v16H4z"/><path d="M4 9h16M9 4v16"/></svg></div><h3>Pipe Repair & Replacement</h3></div>
            <p>Burst pipes, corroded galvanized lines, copper pinhole leaks, and PVC failures. We access, repair, and reroute as needed — with minimal wall opening and complete pressure testing before we close up.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
          <a href="#" class="service-card fade-up d2" data-open-quote="true" data-service="Plumbing" role="button">
            <div class="service-card-top"><div class="service-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 15h18M3 9h18M9 3v6M15 3v6M9 15v6M15 15v6"/></svg></div><h3>Shower & Tub Repair</h3></div>
            <p>Low pressure, temperature issues, cartridge failures, diverter valves, and tub drain replacements. Shower and tub plumbing is some of the most-used in the home. We diagnose accurately and fix it so it works consistently.</p>
            <span class="service-link">Get a quote <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
          </a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="process-section">
      <div class="container">
        <div class="process-intro fade-up">
          <div class="section-eyebrow section-eyebrow--blue">OUR PROCESS</div>
          <h2 class="section-heading section-heading--no-em">From your call to a working plumbing system — every step explained.</h2>
          <p class="section-body">No confusing estimates, no mystery charges. Here's exactly how a plumbing job works with us.</p>
        </div>
        <div class="process-grid fade-up">
          <div class="process-card">
            <span class="process-num">01</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
            <span class="process-pill">Step 01</span>
            <h3>Describe your issue</h3>
            <p>Fill out our quick form or call (818) 584-7389. Tell us what's happening — slow drain, no hot water, visible leak — and your ZIP code. The more detail, the faster we can respond.</p>
          </div>
          <div class="process-card">
            <span class="process-num">02</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
            <span class="process-pill">Step 02</span>
            <h3>We send a licensed plumber</h3>
            <p>We match your job to a licensed plumber in your area. You get their credentials, availability, and an upfront quote before committing. Same-day and emergency availability when you need it fast.</p>
          </div>
          <div class="process-card">
            <span class="process-num">03</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
            <span class="process-pill">Step 03</span>
            <h3>Diagnosis & upfront quote</h3>
            <p>Your plumber arrives, assesses the issue, and gives you a flat-rate quote for the repair before any work starts. No surprises, no verbal estimates that change when the invoice arrives.</p>
          </div>
          <div class="process-card">
            <span class="process-num">04</span>
            <div class="process-icon-wrap"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg></div>
            <span class="process-pill">Step 04</span>
            <h3>Fixed, tested, guaranteed.</h3>
            <p>Work is completed, pressure-tested, and inspected before your plumber leaves. If anything fails within the warranty period, we come back at no charge. That's the guarantee.</p>
          </div>
        </div>
      </div>
    </section>


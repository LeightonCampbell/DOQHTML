---
import Head from '../components/Head.astro';
import HeroNav from '../components/HeroNav.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
import '../styles/global.css';
import '../styles/homepage.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  /** When true, add robots noindex,nofollow to prevent search engine indexing */
  noindex?: boolean;
}

const { title, description, canonical, noindex = false } = Astro.props;
const isHomePage = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} canonical={canonical} noindex={noindex} />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <Modals />
    <HeroNav isHomePage={isHomePage} />
    <main id="main-content" data-hero-nav="true">
      <slot />
    </main>
    <Footer />
  </body>
</html>

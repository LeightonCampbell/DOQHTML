---
import Head from '../components/Head.astro';
import Navbar from '../components/Navbar.astro';
import HeroNav from '../components/HeroNav.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
import '../styles/global.css';
import '../styles/homepage.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  /** When true, use prototype mainNav (transparent → solid on scroll) instead of default Navbar. Homepage only. */
  useHeroNav?: boolean;
  /** When true, add robots noindex,nofollow to prevent search engine indexing */
  noindex?: boolean;
}

const { title, description, canonical, useHeroNav = false, noindex = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} canonical={canonical} noindex={noindex} />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    {useHeroNav ? <HeroNav /> : <Navbar />}
    <main id="main-content" data-hero-nav={useHeroNav ? 'true' : undefined}>
      <slot />
    </main>
    <Footer />
    <Modals />
  </body>
</html>

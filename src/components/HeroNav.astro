---
/**
 * Main nav: transparent at top on homepage (logo-light), solid when scrolled (logo-dark).
 * On non-homepage pages, starts in solid/light state. Uses phone icon from legacy Navbar.
 */
interface Props {
  isHomePage?: boolean;
}
const { isHomePage = false } = Astro.props;
---
<nav id="mainNav" aria-label="Main navigation" class:list={[!isHomePage && 'scrolled']}>
  <div class="nav-inner">
    <a class="logo" href="/" aria-label="Deals of Quality – Home">
      <img src="/images/logo-light.png" alt="Deals of Quality" class="nav-logo nav-logo--light" width="96" height="30" loading="eager" />
      <img src="/images/logo-dark.png" alt="Deals of Quality" class="nav-logo nav-logo--dark" width="96" height="30" loading="eager" />
    </a>
    <ul class="nav-links">
      <li><a href="/services/">Services</a></li>
      <li><a href="/faqs/">FAQs</a></li>
      <li><a href="/articles/">Articles</a></li>
      <li class="nav-phone-li">
        <a class="nav-phone" href="tel:8185847389">
          <svg class="nav-phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          (818) 584-7389
        </a>
      </li>
    </ul>
    <a href="/join-as-pro/" class="nav-join">Join As a Pro</a>
    <a class="nav-phone-mobile" href="tel:8185847389" aria-label="Call (818) 584-7389">
      <svg class="nav-phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
      (818) 584-7389
    </a>
    <button type="button" id="heroNav-menu-btn" class="nav-menu-btn" aria-expanded="false" aria-controls="heroNav-mobile-menu" aria-label="Open menu">
      <svg class="nav-menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="heroNav-mobile-menu" class="nav-mobile-menu" aria-hidden="true">
    <a href="/services/">Services</a>
    <a href="/faqs/">FAQs</a>
    <a href="/articles/">Articles</a>
    <a href="tel:8185847389">(818) 584-7389</a>
    <a href="/join-as-pro/" class="nav-mobile-join">Join As a Pro</a>
  </div>
</nav>

<style is:global>
  /* Prototype NAV: fixed, transparent at top, solid when scrolled */
  #mainNav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(10,10,8,0.55);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(255,255,255,0.10);
    height: 64px;
    display: flex;
    align-items: center;
    transition: background 0.4s;
  }
  #mainNav.scrolled {
    background: rgba(250,250,248,0.95);
    border-bottom-color: #E8E5E0;
  }
  #mainNav .nav-logo--light { display: block; }
  #mainNav .nav-logo--dark { display: none; }
  #mainNav.scrolled .nav-logo--light { display: none; }
  #mainNav.scrolled .nav-logo--dark { display: block; }
  #mainNav.scrolled .nav-links a {
    color: #111827;
    font-weight: 600;
  }
  #mainNav.scrolled .nav-links a:hover { color: #141210; }
  #mainNav.scrolled .nav-phone {
    color: #111827 !important;
    font-weight: 600;
  }

  #mainNav .nav-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  #mainNav .nav-links {
    flex: 1;
    justify-content: center;
  }
  #mainNav .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 30px;
  }
  #mainNav .nav-logo {
    height: 24px;
    width: auto;
    object-fit: contain;
    object-position: left center;
  }
  @media (min-width: 768px) {
    #mainNav .nav-logo { height: 30px; }
  }
  #mainNav .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #mainNav .nav-links a {
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.95);
    text-decoration: none;
    transition: color 0.2s;
  }
  #mainNav .nav-links a:hover { color: #fff; }
  #mainNav .nav-phone {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.95) !important;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color 0.4s !important;
  }
  #mainNav .nav-phone svg,
  #mainNav .nav-phone-icon { width: 20px; height: 20px; flex-shrink: 0; }
  #mainNav .nav-join {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.9) !important;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 7px 14px;
    border-radius: 6px;
    text-decoration: none;
    flex-shrink: 0;
  }
  #mainNav .nav-join:hover { color: #fff !important; border-color: rgba(255,255,255,0.4); }
  #mainNav.scrolled .nav-join {
    color: #111827 !important;
    font-weight: 600;
    border-color: #E8E5E0;
  }
  #mainNav.scrolled .nav-join:hover { color: #141210 !important; border-color: #E8E5E0; }
  #mainNav .nav-phone-mobile {
    display: none;
  }
  #mainNav .nav-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    color: rgba(255,255,255,0.95);
    transition: background 0.2s, color 0.2s;
  }
  #mainNav .nav-menu-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  #mainNav.scrolled .nav-menu-btn { color: #111827; }
  #mainNav.scrolled .nav-menu-btn:hover { background: rgba(0,0,0,0.06); }
  #mainNav .nav-menu-icon { width: 24px; height: 24px; }
  #mainNav .nav-mobile-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: rgba(17,24,39,0.98);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    flex-direction: column;
    padding: 12px 16px 20px;
    gap: 4px;
    z-index: 199;
  }
  #mainNav .nav-mobile-menu.is-open { display: flex; }
  #mainNav .nav-mobile-menu a {
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 8px;
    transition: background 0.2s;
  }
  #mainNav .nav-mobile-menu a:hover { background: rgba(255,255,255,0.1); }
  #mainNav .nav-mobile-join {
    margin-top: 8px;
    border: 1px solid rgba(255,255,255,0.25);
    text-align: center;
  }
  @media (max-width: 820px) {
    #mainNav .nav-links { display: none; }
    #mainNav .nav-join { display: none !important; }
    #mainNav .nav-phone-mobile {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 13px;
      font-weight: 600;
      color: rgba(255,255,255,0.95) !important;
      text-decoration: none;
      flex-shrink: 0;
    }
    #mainNav .nav-phone-mobile svg,
    #mainNav .nav-phone-mobile .nav-phone-icon { width: 20px; height: 20px; }
    #mainNav.scrolled .nav-phone-mobile { color: #111827 !important; }
    #mainNav .nav-inner {
      flex-wrap: nowrap;
    }
    #mainNav .logo { order: 0; }
    #mainNav .nav-phone-mobile { order: 1; }
    #mainNav .nav-menu-btn { order: 2; display: flex; }
    #mainNav .nav-links { order: 3; }
  }
  @media (max-width: 480px) {
    #mainNav .nav-phone-li { display: none; }
  }
</style>

<script define:vars={{ isHomePage }}>
  (function () {
    const mainNav = document.getElementById('mainNav');
    if (!mainNav) return;
    function updateNav() {
      if (!isHomePage) return;
      mainNav.classList.toggle('scrolled', window.scrollY > 80);
    }
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    const menuBtn = document.getElementById('heroNav-menu-btn');
    const mobileMenu = document.getElementById('heroNav-mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', function () {
        const open = mobileMenu.classList.toggle('is-open');
        menuBtn.setAttribute('aria-expanded', open);
        menuBtn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        mobileMenu.setAttribute('aria-hidden', !open);
      });
      mobileMenu.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          mobileMenu.classList.remove('is-open');
          menuBtn.setAttribute('aria-expanded', 'false');
          menuBtn.setAttribute('aria-label', 'Open menu');
          mobileMenu.setAttribute('aria-hidden', 'true');
        });
      });
    }
  })();
</script>

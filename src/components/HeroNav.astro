---
/**
 * Prototype mainNav: transparent at top (logo-light), solid when scrolled (logo-dark).
 * Used on homepage only. Nav links go to respective pages.
 */
---
<nav id="mainNav" aria-label="Main navigation">
  <div class="nav-inner">
    <a class="logo" href="/" aria-label="Deals of Quality – Home">
      <img src="/images/logo-light.png" alt="Deals of Quality" class="nav-logo nav-logo--light" width="96" height="30" loading="eager" />
      <img src="/images/logo-dark.png" alt="Deals of Quality" class="nav-logo nav-logo--dark" width="96" height="30" loading="eager" />
    </a>
    <ul class="nav-links">
      <li><a href="/services/">Services</a></li>
      <li><a href="/faqs/">FAQs</a></li>
      <li><a href="/articles/">Articles</a></li>
      <li class="nav-phone-li">
        <a class="nav-phone" href="tel:8185847389">
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M14.5 11.5c0 .3-.1.6-.2.9-.2.3-.4.6-.6.8-.4.4-.8.6-1.3.6-.3 0-.7-.1-1-.2l-1-.4c-.9-.4-1.8-1-2.6-1.8C7 10.6 6.4 9.7 6 8.8l-.4-1c-.1-.3-.2-.7-.2-1 0-.5.2-.9.5-1.3.3-.4.7-.6 1.1-.6.2 0 .3 0 .5.1.2.1.3.2.4.4l1.4 2c.1.2.2.3.2.5 0 .2-.1.4-.2.5l-.4.4c0 .1-.1.1-.1.2.3.5.7 1 1.1 1.4.4.4.9.8 1.4 1.1l.2-.1.4-.4c.2-.2.3-.2.5-.2.2 0 .4.1.5.2l2 1.4c.2.1.3.3.4.4 0 .2.1.3.1.5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          (818) 584-7389
        </a>
      </li>
    </ul>
    <a href="/join-as-pro/" class="nav-join">Join As a Pro</a>
  </div>
</nav>

<style is:global>
  /* Prototype NAV: fixed, transparent at top, solid when scrolled */
  #mainNav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(10,10,8,0.55);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(255,255,255,0.10);
    height: 64px;
    display: flex;
    align-items: center;
    transition: background 0.4s;
  }
  #mainNav.scrolled {
    background: rgba(250,250,248,0.95);
    border-bottom-color: #E8E5E0;
  }
  #mainNav .nav-logo--light { display: block; }
  #mainNav .nav-logo--dark { display: none; }
  #mainNav.scrolled .nav-logo--light { display: none; }
  #mainNav.scrolled .nav-logo--dark { display: block; }
  #mainNav.scrolled .nav-links a {
    color: #111827;
    font-weight: 600;
  }
  #mainNav.scrolled .nav-links a:hover { color: #141210; }
  #mainNav.scrolled .nav-phone {
    color: #111827 !important;
    font-weight: 600;
  }

  #mainNav .nav-inner {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  #mainNav .nav-links {
    flex: 1;
    justify-content: center;
  }
  #mainNav .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    height: 30px;
  }
  #mainNav .nav-logo {
    height: 24px;
    width: auto;
    object-fit: contain;
    object-position: left center;
  }
  @media (min-width: 768px) {
    #mainNav .nav-logo { height: 30px; }
  }
  #mainNav .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #mainNav .nav-links a {
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.95);
    text-decoration: none;
    transition: color 0.2s;
  }
  #mainNav .nav-links a:hover { color: #fff; }
  #mainNav .nav-phone {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.95) !important;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color 0.4s !important;
  }
  #mainNav .nav-phone svg { width: 15px; height: 15px; }
  #mainNav .nav-join {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.9) !important;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 7px 14px;
    border-radius: 6px;
    text-decoration: none;
    flex-shrink: 0;
  }
  #mainNav .nav-join:hover { color: #fff !important; border-color: rgba(255,255,255,0.4); }
  #mainNav.scrolled .nav-join {
    color: #111827 !important;
    font-weight: 600;
    border-color: #E8E5E0;
  }
  #mainNav.scrolled .nav-join:hover { color: #141210 !important; border-color: #E8E5E0; }
  @media (max-width: 820px) {
    #mainNav .nav-links { flex: 0 1 auto; }
    #mainNav .nav-links li:not(:last-child):not(.nav-phone-li) { display: none; }
  }
  @media (max-width: 480px) {
    #mainNav .nav-phone-li { display: none; }
  }
</style>

<script>
  (function () {
    const mainNav = document.getElementById('mainNav');
    if (!mainNav) return;
    function updateNav() {
      mainNav.classList.toggle('scrolled', window.scrollY > 80);
    }
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  })();
</script>

# Resend (https://resend.com) – paste your API key for quote/booking email notifications
RESEND_API_KEY=

# Optional: where to receive notification emails (defaults to notifications@dealsofquality.com)
# NOTIFICATION_EMAIL=you@example.com

# Optional: "from" address for sent emails (must use a verified domain in Resend; default: onboarding@resend.dev)
# FROM_EMAIL=Deals of Quality <notifications@yourdomain.com>

# Optional: Discord webhook URL for push notifications on new leads (e.g. https://discord.com/api/webhooks/...)
# DISCORD_WEBHOOK_URL=
